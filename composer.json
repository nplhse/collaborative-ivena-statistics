{
    "name": "nplhse/collaborative-ivena-statistics",
    "description": "A Symfony based webapp for Data Science related to german EMS data from the \"IVENA eHealth\" system.",
    "type": "project",
    "homepage": "https://github.com/nplhse/collaborative-ivena-statistics/",
    "license": "MIT",
    "authors": [
        {
            "name": "Christoph Steltner",
            "email": "mail@nplhse.com",
            "homepage": "http://nplhse.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nplhse/collaborative-ivena-statistics/issues"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^2.18.2",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.6.7",
        "dragonmantank/cron-expression": "^3.1",
        "easycorp/easyadmin-bundle": "^4.29.11",
        "phpdocumentor/reflection-docblock": "^5.6.7",
        "phpstan/phpdoc-parser": "^2.3.2",
        "sentry/sentry-symfony": "^5.10",
        "symfony/asset": "7.4.*",
        "symfony/asset-mapper": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/doctrine-messenger": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/expression-language": "7.4.*",
        "symfony/flex": "^2.11",
        "symfony/form": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/html-sanitizer": "^7.4.13",
        "symfony/http-client": "7.4.*",
        "symfony/intl": "7.4.*",
        "symfony/lock": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/mime": "7.4.*",
        "symfony/monolog-bundle": "^3.11.2",
        "symfony/notifier": "7.4.*",
        "symfony/polyfill-intl-messageformatter": "^1.38",
        "symfony/polyfill-intl-normalizer": "^1.38",
        "symfony/process": "7.4.*",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/rate-limiter": "^7.4.13",
        "symfony/runtime": "7.4.*",
        "symfony/scheduler": "^7.4",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/stimulus-bundle": "^2.36",
        "symfony/string": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/ux-icons": "^2.36",
        "symfony/ux-live-component": "^2.36",
        "symfony/ux-turbo": "^2.36",
        "symfony/ux-twig-component": "^2.36",
        "symfony/validator": "7.4.*",
        "symfony/web-link": "7.4.*",
        "symfony/yaml": "7.4.*",
        "symfonycasts/reset-password-bundle": "^1.25",
        "symfonycasts/verify-email-bundle": "^1.18",
        "twig/extra-bundle": "^2.12|^3.24",
        "twig/intl-extra": "^3.26",
        "twig/twig": "^2.12|^3.27",
        "vich/uploader-bundle": "^2.9"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "setup-database": [
            "@php bin/console doctrine:database:drop --if-exists --force",
            "@php bin/console doctrine:database:create",
            "@php bin/console doctrine:migrations:migrate --no-interaction"
        ],
        "load-fixtures": [
            "@php bin/console doctrine:fixtures:load --no-interaction"
        ],
        "setup-env": [
            "@setup-database",
            "@load-fixtures"
        ],
        "setup-test-env": [
            "@php bin/console doctrine:database:drop --if-exists --force --env test",
            "@php bin/console doctrine:database:create --env test",
            "@php bin/console doctrine:migrations:migrate --no-interaction --env test"
        ],
        "upgrade-test-env": [
            "@setup-test-env"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "^7.4"
        }
    },
    "require-dev": {
        "deployer/deployer": "^8.0.5",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "friendsofphp/php-cs-fixer": "^3.95.3",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.2.1",
        "phpstan/phpstan-doctrine": "^2.0.23",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "phpstan/phpstan-symfony": "^2.0.19",
        "phpunit/phpunit": "^12.5.28",
        "psalm/plugin-phpunit": "^0.19.7",
        "psalm/plugin-symfony": "^5.3",
        "rector/rector": "^2.4.5",
        "roave/security-advisories": "dev-latest",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/debug-bundle": "7.4.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/stopwatch": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*",
        "vimeo/psalm": "^6.16.1",
        "vincentlanglet/twig-cs-fixer": "^3.14",
        "weirdan/doctrine-psalm-plugin": "^2.10",
        "zenstruck/browser": "^1.10.1",
        "zenstruck/foundry": "^2.10.1"
    }
}
