{
    "name": "nplhse/collaborative-ivena-statistics",
    "description": "A Symfony based webapp for Data Science related to german EMS data from the \"IVENA eHealth\" system.",
    "type": "project",
    "homepage": "https://github.com/nplhse/collaborative-ivena-statistics/",
    "license": "MIT",
    "authors": [
        {
            "name": "Christoph Steltner",
            "email": "mail@nplhse.com",
            "homepage": "http://nplhse.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nplhse/collaborative-ivena-statistics/issues"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.4",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.7",
        "dragonmantank/cron-expression": "^3.6",
        "easycorp/easyadmin-bundle": "^4.29.13",
        "nelmio/security-bundle": "^3.9",
        "phpdocumentor/reflection-docblock": "^5.6.7",
        "phpstan/phpdoc-parser": "^2.3.2",
        "sentry/sentry-symfony": "^5.10",
        "symfony/asset": "8.1.*",
        "symfony/asset-mapper": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/doctrine-messenger": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/expression-language": "8.1.*",
        "symfony/flex": "^2.11",
        "symfony/form": "8.1.*",
        "symfony/framework-bundle": "8.1.*",
        "symfony/html-sanitizer": "^8.1",
        "symfony/http-client": "8.1.*",
        "symfony/intl": "8.1.*",
        "symfony/lock": "8.1.*",
        "symfony/mailer": "8.1.*",
        "symfony/mime": "8.1.*",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/notifier": "8.1.*",
        "symfony/polyfill-intl-messageformatter": "^1.38",
        "symfony/polyfill-intl-normalizer": "^1.38",
        "symfony/process": "8.1.*",
        "symfony/property-access": "8.1.*",
        "symfony/property-info": "8.1.*",
        "symfony/rate-limiter": "^8.1",
        "symfony/runtime": "8.1.*",
        "symfony/scheduler": "^8.1",
        "symfony/security-bundle": "8.1.*",
        "symfony/serializer": "8.1.*",
        "symfony/stimulus-bundle": "^2.36",
        "symfony/string": "8.1.*",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/uid": "8.1.*",
        "symfony/ux-icons": "^2.36.1",
        "symfony/ux-live-component": "^2.36",
        "symfony/ux-turbo": "^2.36",
        "symfony/ux-twig-component": "^2.36",
        "symfony/validator": "8.1.*",
        "symfony/web-link": "8.1.*",
        "symfony/yaml": "8.1.*",
        "symfonycasts/reset-password-bundle": "^1.25",
        "symfonycasts/verify-email-bundle": "^1.18",
        "twig/extra-bundle": "^3.24",
        "twig/intl-extra": "^3.26",
        "twig/twig": "^3.27.1",
        "vich/uploader-bundle": "^2.9.4"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "setup-database": [
            "@php bin/console doctrine:database:drop --if-exists --force",
            "@php bin/console doctrine:database:create",
            "@php bin/console doctrine:migrations:migrate --no-interaction"
        ],
        "load-fixtures": [
            "@php bin/console doctrine:fixtures:load --group=dev --no-interaction"
        ],
        "setup-env": [
            "@setup-database",
            "@load-fixtures"
        ],
        "setup-test-env": [
            "@php bin/console cache:clear --no-warmup --env test",
            "@php bin/console doctrine:database:drop --if-exists --force --env test",
            "@php bin/console doctrine:database:create --env test",
            "@php bin/console doctrine:migrations:migrate --no-interaction --env test"
        ],
        "upgrade-test-env": [
            "@setup-test-env"
        ],
        "check-deprecations": [
            "@php bin/check-deprecations"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "^8.1"
        }
    },
    "require-dev": {
        "brianium/paratest": "^7.20",
        "dama/doctrine-test-bundle": "^8.6",
        "deployer/deployer": "^8.0.5",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "friendsofphp/php-cs-fixer": "^3.95.10",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.2.2",
        "phpstan/phpstan-doctrine": "^2.0.27",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "phpstan/phpstan-symfony": "^2.0.20",
        "phpunit/phpunit": "^12.5.30",
        "psalm/plugin-phpunit": "^0.19.7",
        "psalm/plugin-symfony": "^5.3",
        "rector/rector": "^2.5.2",
        "rector/swiss-knife": "^2.4.8",
        "roave/security-advisories": "dev-latest",
        "symfony/browser-kit": "8.1.*",
        "symfony/css-selector": "8.1.*",
        "symfony/debug-bundle": "8.1.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/stopwatch": "8.1.*",
        "symfony/web-profiler-bundle": "8.1.*",
        "vimeo/psalm": "^6.16.1",
        "vincentlanglet/twig-cs-fixer": "^3.14",
        "weirdan/doctrine-psalm-plugin": "^2.10",
        "zenstruck/browser": "^1.10.1",
        "zenstruck/foundry": "^2.10.1"
    }
}
