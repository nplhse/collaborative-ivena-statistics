{% set infectionSelectId = infectionSelectId|default('filter-infection') %}
{% set testIdPrefix = testIdPrefix|default(null) %}

<div class="allocation-filter-checkboxes">
    <div class="allocation-filter-checkbox-group">
        <label class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   name="requiresResus"
                   value="1"
                   {% if testIdPrefix is not empty %}data-testid="{{ testIdPrefix }}-requires-resus"{% endif %}
                   {{ values.requiresResus ? 'checked' }}>
            <span class="form-check-label">{{ 'label.requires_resus'|trans({}, 'messages') }}</span>
        </label>
        <label class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   name="requiresCathlab"
                   value="1"
                   {% if testIdPrefix is not empty %}data-testid="{{ testIdPrefix }}-requires-cathlab"{% endif %}
                   {{ values.requiresCathlab ? 'checked' }}>
            <span class="form-check-label">{{ 'label.requires_cathlab'|trans({}, 'messages') }}</span>
        </label>
    </div>

    <div class="allocation-filter-checkbox-group">
        <label class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   name="isVentilated"
                   value="1"
                   {% if testIdPrefix is not empty %}data-testid="{{ testIdPrefix }}-is-ventilated"{% endif %}
                   {{ values.isVentilated ? 'checked' }}>
            <span class="form-check-label">{{ 'label.is_ventilated'|trans({}, 'messages') }}</span>
        </label>
        <label class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   name="isShock"
                   value="1"
                   {% if testIdPrefix is not empty %}data-testid="{{ testIdPrefix }}-is-shock"{% endif %}
                   {{ values.isShock ? 'checked' }}>
            <span class="form-check-label">{{ 'label.is_shock'|trans({}, 'messages') }}</span>
        </label>
        <label class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   name="isCPR"
                   value="1"
                   {% if testIdPrefix is not empty %}data-testid="{{ testIdPrefix }}-is-cpr"{% endif %}
                   {{ values.isCPR ? 'checked' }}>
            <span class="form-check-label">{{ 'label.is_cpr'|trans({}, 'messages') }}</span>
        </label>
        <label class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   name="isPregnant"
                   value="1"
                   {% if testIdPrefix is not empty %}data-testid="{{ testIdPrefix }}-is-pregnant"{% endif %}
                   {{ values.isPregnant ? 'checked' }}>
            <span class="form-check-label">{{ 'label.is_pregnant'|trans({}, 'messages') }}</span>
        </label>
        <label class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   name="isWorkAccident"
                   value="1"
                   {% if testIdPrefix is not empty %}data-testid="{{ testIdPrefix }}-is-work-accident"{% endif %}
                   {{ values.isWorkAccident ? 'checked' }}>
            <span class="form-check-label">{{ 'label.is_work_accident'|trans({}, 'messages') }}</span>
        </label>
    </div>

    <div class="allocation-filter-checkbox-group" data-controller="infection-filter">
        <label class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   name="isInfectious"
                   value="1"
                   {% if testIdPrefix is not empty %}data-testid="{{ testIdPrefix }}-is-infectious"{% endif %}
                   data-infection-filter-target="toggle"
                   data-action="change->infection-filter#sync"
                   {{ values.isInfectious ? 'checked' }}>
            <span class="form-check-label">{{ 'label.is_infectious'|trans({}, 'messages') }}</span>
        </label>
        <div class="{{ values.isInfectious ? '' : 'd-none' }}" data-infection-filter-target="panel">
            <label class="form-label" for="{{ infectionSelectId }}">{{ 'label.infection'|trans({}, 'messages') }}</label>
            <select id="{{ infectionSelectId }}"
                    name="infection"
                    class="form-select"
                    {% if testIdPrefix is not empty %}data-testid="{{ testIdPrefix }}-infection"{% endif %}
                    data-infection-filter-target="select"
                    {{ values.isInfectious ? '' : 'disabled' }}>
                <option value="">{{ 'label.all_infections'|trans({}, 'messages') }}</option>
                {% if infectionChoices is defined %}
                    {% for choiceKey, choiceLabel in infectionChoices %}
                        <option value="{{ choiceKey }}" {{ values.infection == choiceKey ? 'selected' }}>{{ choiceLabel }}</option>
                    {% endfor %}
                {% else %}
                    {% for infection in infections %}
                        <option value="{{ infection.id }}" {{ values.infection == infection.id ? 'selected' }}>{{ infection.name }}</option>
                    {% endfor %}
                {% endif %}
            </select>
        </div>
    </div>
</div>
