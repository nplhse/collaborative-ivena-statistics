{% set activeFilterCount = activeFilterCount|default(0) %}

<div class="btn-group">
    <button type="button"
            class="btn"
            data-bs-toggle="offcanvas"
            data-bs-target="#{{ drawerId }}"
            aria-controls="{{ drawerId }}"
            {% if openTestId is defined and openTestId %}data-testid="{{ openTestId }}"{% endif %}>
        {% if activeFilterCount < 1 %}
            <svg xmlns="http://www.w3.org/2000/svg"
                 class="icon"
                 width="24"
                 height="24"
                 viewBox="0 0 24 24"
                 stroke-width="2"
                 stroke="currentColor"
                 fill="none"
                 stroke-linecap="round"
                 stroke-linejoin="round"
                 aria-hidden="true">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M4 4h16l-6 8v6l-4 -2v-4z" />
            </svg>
        {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="currentColor" d="M20 3H4a1 1 0 0 0-1 1v2.227l.008.223a3 3 0 0 0 .772 1.795L8 12.886V21a1 1 0 0 0 1.316.949l6-2l.108-.043A1 1 0 0 0 16 19v-6.586l4.121-4.12A3 3 0 0 0 21 6.171V4a1 1 0 0 0-1-1"/>
            </svg>
        {% endif %}
        <span class="ms-2">{{ 'label.filters'|trans }}</span>
        {% if activeFilterCount > 0 %}
            <span class="badge text-primary ms-2">{{ activeFilterCount }}</span>
        {% endif %}
    </button>

    {% if activeFilterCount > 0 and resetUrl is defined and resetUrl %}
        <a href="{{ resetUrl }}"
           class="btn btn-icon btn-outline"
           title="{{ 'label.filters.reset'|trans }}"
           aria-label="{{ 'label.filters.reset'|trans }}"
           {% if clearTestId is defined and clearTestId %}data-testid="{{ clearTestId }}"{% endif %}>
            <svg xmlns="http://www.w3.org/2000/svg"
                 class="icon"
                 width="24"
                 height="24"
                 viewBox="0 0 24 24"
                 stroke-width="2"
                 stroke="currentColor"
                 fill="none"
                 stroke-linecap="round"
                 stroke-linejoin="round"
                 aria-hidden="true">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M18 6l-12 12" />
                <path d="M6 6l12 12" />
            </svg>
        </a>
    {% endif %}
</div>
