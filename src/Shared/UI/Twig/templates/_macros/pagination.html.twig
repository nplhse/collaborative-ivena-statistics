{% macro sortArrow(sortName, sortBy, orderBy) %}
    {% if sortBy == sortName %}
        {% if orderBy == 'asc' %}
            <twig:ux:icon name="tabler:chevron-up" width="1em" height="1em" />
        {% else %}
            <twig:ux:icon name="tabler:chevron-down" width="1em" height="1em" />
        {% endif %}
    {% else %}
        <twig:ux:icon name="tabler:selector" width="1em" height="1em" />
    {% endif %}
{% endmacro %}

{% macro results(numResults, pageSize) %}
    <div class="dropdown">
        <a class="btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="me-1">
                {{ 'label.pagination_results'|trans(({pageSize: pageSize}), 'messages') }}
            </span>
        </a>
        <div class="dropdown-menu">
            <a class="dropdown-item"
               href="{{ path(app.request.attributes.get('_route'),
                   app.request.query.all|merge({limit: 25, page: 1})) }}">
                {{ 'label.pagination_results'|trans(({pageSize: 25}), 'messages') }}
            </a>
            <a class="dropdown-item"
               href="{{ path(app.request.attributes.get('_route'),
                   app.request.query.all|merge({limit: 50, page: 1})) }}">
                {{ 'label.pagination_results'|trans(({pageSize: 50}), 'messages') }}
            </a>
            <a class="dropdown-item"
               href="{{ path(app.request.attributes.get('_route'),
                   app.request.query.all|merge({limit: 100, page: 1})) }}">
                {{ 'label.pagination_results'|trans(({pageSize: 100}), 'messages') }}
            </a>
        </div>
    </div>
{% endmacro %}

{# Wie {{ results() }}, aber mit vorgegebenen Ziel-URLs (z. B. Statistics-Reports, Limit ohne Pagination). #}
{% macro rowLimitDropdown(limitUrls, currentLimit) %}
    <div class="dropdown">
        <a class="btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" data-testid="stats-reports-limit-trigger">
            <span class="me-1">
                {{ 'label.pagination_results'|trans(({pageSize: currentLimit}), 'messages') }}
            </span>
        </a>
        <div class="dropdown-menu">
            {% for size, url in limitUrls %}
                <a class="dropdown-item{% if size == currentLimit %} active{% endif %}"
                   href="{{ url }}"
                   data-testid="stats-reports-limit-{{ size }}">
                    {{ 'label.pagination_results'|trans(({pageSize: size}), 'messages') }}
                </a>
            {% endfor %}
        </div>
    </div>
{% endmacro %}

{% macro navbar(paginator, targetPath) %}
    {% if paginator.hasToPaginate %}
        {% set query = app.request.query.all %}
        <ul class="pagination m-0 ms-auto">
            {% if paginator.hasPreviousPage %}
                <li class="page-item">
                    <a class="page-link" href="{{ path(targetPath, query|merge({page: paginator.previousPage})) }}" tabindex="-1" aria-disabled="true">
                        <twig:ux:icon name="tabler:chevron-left" width="1em" height="1em" />
                        {{ 'label.previous'|trans({}, 'messages') }}
                    </a>
                </li>
            {% else %}
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1" aria-disabled="true">
                        <twig:ux:icon name="tabler:chevron-left" width="1em" height="1em" />
                        {{ 'label.previous'|trans({}, 'messages') }}
                    </a>
                </li>
            {% endif %}
            {% if 2 >= paginator.lastPage %}
                {% for i in 1..paginator.lastPage %}
                    {% if i == paginator.currentPage %}
                        <li class="page-item active">
                            <span class="page-link">{{ i }}</span>
                        </li>
                    {% else %}
                        <li class="page-item"><a class="page-link" href="{{ path(targetPath, query|merge({page: i})) }}">{{ i }}</a></li>
                    {% endif %}
                {% endfor %}
            {% else %}
                {% if 1 > paginator.currentPage - 1 and paginator.currentPage < paginator.lastPage %}
                    {% set min = 1 %}
                    {% set max = paginator.currentPage + 2 %}
                {% elseif 1 <= paginator.currentPage - 1 and paginator.currentPage < paginator.lastPage %}
                    {% set min = paginator.currentPage - 1 %}
                    {% set max = paginator.currentPage + 1 %}
                {% elseif 1 <= paginator.currentPage - 1 and paginator.currentPage >= paginator.lastPage %}
                    {% set min = paginator.currentPage - 2 %}
                    {% set max = paginator.currentPage %}
                {% endif %}
                {% if paginator.currentPage > 3 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path(targetPath, query|merge({page: 1})) }}">1 ...</a>
                    </li>
                {% endif %}
                {% for i in min..max %}
                    {% if i == paginator.currentPage %}
                        <li class="page-item active">
                            <span class="page-link" >{{ i }}</span>
                        </li>
                    {% else %}
                        <li class="page-item"><a class="page-link" href="{{ path(targetPath, query|merge({page: i})) }}">{{ i }}</a></li>
                    {% endif %}
                {% endfor %}
                {% if paginator.lastPage - paginator.currentPage > 2 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path(targetPath, query|merge({page: paginator.lastPage})) }}">... {{ paginator.lastPage }}</a>
                    </li>
                {% endif %}
            {% endif %}
            {% if paginator.hasNextPage %}
                <li class="page-item">
                    <a class="page-link" href="{{ path(targetPath, query|merge({page: paginator.nextPage})) }}">
                        {{ 'label.next'|trans({}, 'messages') }}
                        <twig:ux:icon name="tabler:chevron-right" width="1em" height="1em" />
                    </a>
                </li>
            {% else %}
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1" aria-disabled="true">
                        {{ 'label.next'|trans({}, 'messages') }}
                        <twig:ux:icon name="tabler:chevron-right" width="1em" height="1em" />
                    </a>
                </li>
            {% endif %}
        </ul>
    {% endif %}
{% endmacro %}
