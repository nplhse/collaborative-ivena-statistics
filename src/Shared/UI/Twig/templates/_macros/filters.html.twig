{% macro allocation_filter_badges(filters, states, dispatchAreas, indications, secondaryTransports, infections, departments, specialities, transportTypes, hospitalScopeOptions = null) %}
    {% set rawFilters = [] %}

    {% set selectedHospitalFilter = filters.resolvedHospitalFilter %}
    {% if selectedHospitalFilter is not empty and hospitalScopeOptions is not null %}
        {% if selectedHospitalFilter == 'my_hospitals' %}
            {% set rawFilters = rawFilters|merge([{key: 'label.hospital', value: hospitalScopeOptions.scopeLabel}]) %}
        {% else %}
            {% set hospitalName = null %}
            {% for hospital in hospitalScopeOptions.hospitals %}
                {% if hospitalName is null and hospital.id == selectedHospitalFilter %}
                    {% set hospitalName = hospital.name %}
                {% endif %}
            {% endfor %}
            {% if hospitalName is not null %}
                {% set rawFilters = rawFilters|merge([{key: 'label.hospital', value: hospitalName}]) %}
            {% endif %}
        {% endif %}
    {% endif %}

    {# --- Simple string filters --- #}
    {% if filters.urgency is not empty %}
        {% set urgencyKey = 'allocation.urgency.' ~ filters.urgency %}

        {% set rawFilters = rawFilters|merge([{
            key: 'label.urgency',
            value: urgencyKey|trans,
            }]) %}
    {% endif %}

    {% if filters.size is not empty %}
        {% set rawFilters = rawFilters|merge([{key: 'label.size', value: filters.size}]) %}
    {% endif %}

    {% if filters.location is not empty %}
        {% set rawFilters = rawFilters|merge([{key: 'label.location', value: filters.location}]) %}
    {% endif %}

    {% if filters.tier is not empty %}
        {% set rawFilters = rawFilters|merge([{key: 'label.tier', value: filters.tier}]) %}
    {% endif %}

    {% if filters.importId is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.importId', value: filters.importId}]) %}
    {% endif %}

    {# --- Boolean-like filters --- #}
    {% if filters.requiresResus is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.requires_resus', value: filters.requiresResus ? 'Yes' : 'No'}]) %}
    {% endif %}

    {% if filters.requiresCathlab is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.requires_cathlab', value: filters.requiresCathlab ? 'Yes' : 'No'}]) %}
    {% endif %}

    {% if filters.isVentilated is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.is_ventilated', value: filters.isVentilated ? 'Yes' : 'No'}]) %}
    {% endif %}

    {% if filters.isShock is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.is_shock', value: filters.isShock ? 'Yes' : 'No'}]) %}
    {% endif %}

    {% if filters.isCPR is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.is_cpr', value: filters.isCPR ? 'Yes' : 'No'}]) %}
    {% endif %}

    {% if filters.isPregnant is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.is_pregnant', value: filters.isPregnant ? 'Yes' : 'No'}]) %}
    {% endif %}

    {% if filters.isWorkAccident is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.is_work_accident', value: filters.isWorkAccident ? 'Yes' : 'No'}]) %}
    {% endif %}

    {% if filters.isInfectious is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.is_infectious', value: filters.isInfectious ? 'Yes' : 'No'}]) %}
    {% endif %}

    {# --- Lookup: State (id → name) --- #}
    {% if filters.state is not null %}
        {% set stateName = null %}
        {% for s in states %}
            {% if stateName is null and s.id == filters.state %}
                {% set stateName = s.name %}
            {% endif %}
        {% endfor %}
        {% if stateName is not null %}
            {% set rawFilters = rawFilters|merge([{key: 'label.state', value: stateName}]) %}
        {% endif %}
    {% endif %}

    {# --- Lookup: Dispatch Area (id → name) --- #}
    {% if filters.dispatchArea is not null %}
        {% set areaName = null %}
        {% for a in dispatchAreas %}
            {% if areaName is null and a.id == filters.dispatchArea %}
                {% set areaName = a.name %}
            {% endif %}
        {% endfor %}
        {% if areaName is not null %}
            {% set rawFilters = rawFilters|merge([{key: 'label.dispatch_area', value: areaName}]) %}
        {% endif %}
    {% endif %}

    {# --- Lookup: Indication (code → name) --- #}
    {% if filters.indication is not null %}
        {% set indicationName = null %}
        {% for i in indications %}
            {% if indicationName is null and i.code == filters.indication %}
                {% set indicationName = i.name %}
            {% endif %}
        {% endfor %}
        {% if indicationName is not null %}
            {% set rawFilters = rawFilters|merge([{key: 'label.indication', value: indicationName}]) %}
        {% endif %}
    {% endif %}

    {# --- Lookup: Secondary Transport (id → name) --- #}
    {% if filters.secondaryTransport is not null and secondaryTransports is defined %}
        {% set secondaryTransportName = null %}
        {% for st in secondaryTransports %}
            {% if secondaryTransportName is null and st.id == filters.secondaryTransport %}
                {% set secondaryTransportName = st.name %}
            {% endif %}
        {% endfor %}
        {% if secondaryTransportName is not null %}
            {% set rawFilters = rawFilters|merge([{key: 'label.secondary_transport', value: secondaryTransportName}]) %}
        {% endif %}
    {% endif %}

    {# --- Lookup: Department (id → name) --- #}
    {% if filters.department is not null and departments is defined %}
        {% set departmentName = null %}
        {% for department in departments %}
            {% if departmentName is null and department.id == filters.department %}
                {% set departmentName = department.name %}
            {% endif %}
        {% endfor %}
        {% if departmentName is not null %}
            {% set rawFilters = rawFilters|merge([{key: 'label.department', value: departmentName}]) %}
        {% endif %}
    {% endif %}

    {# --- Lookup: Speciality (id → name) --- #}
    {% if filters.speciality is not null and specialities is defined %}
        {% set specialityName = null %}
        {% for speciality in specialities %}
            {% if specialityName is null and speciality.id == filters.speciality %}
                {% set specialityName = speciality.name %}
            {% endif %}
        {% endfor %}
        {% if specialityName is not null %}
            {% set rawFilters = rawFilters|merge([{key: 'label.speciality', value: specialityName}]) %}
        {% endif %}
    {% endif %}

    {# --- Transport type --- #}
    {% if filters.transportType is not empty and transportTypes is defined %}
        {% set transportTypeLabel = null %}
        {% for transportType in transportTypes %}
            {% if transportTypeLabel is null and transportType.value == filters.transportType %}
                {% set transportTypeLabel = transportType.label()|trans %}
            {% endif %}
        {% endfor %}
        {% if transportTypeLabel is not null %}
            {% set rawFilters = rawFilters|merge([{key: 'stats.analysis_explorer.dimension.transport_type', value: transportTypeLabel}]) %}
        {% endif %}
    {% endif %}

    {# --- Lookup: Infection (id → name) --- #}
    {% if filters.infection is not null and infections is defined %}
        {% set infectionName = null %}
        {% for inf in infections %}
            {% if infectionName is null and inf.id == filters.infection %}
                {% set infectionName = inf.name %}
            {% endif %}
        {% endfor %}
        {% if infectionName is not null %}
            {% set rawFilters = rawFilters|merge([{key: 'label.infection', value: infectionName}]) %}
        {% endif %}
    {% endif %}

    {# 2. Manual alphabetical sort #}
    {% set byKey = {} %}
    {% for f in rawFilters %}
        {% set byKey = byKey|merge({(f.key): f.value}) %}
    {% endfor %}

    {% set sortedKeys = byKey|keys|sort %}

    {# 3. Render badges #}
    {% if sortedKeys is not empty %}
        <div class="d-flex flex-wrap gap-1">
            {% for key in sortedKeys %}
                <span class="badge bg-blue-lt">
                    <strong>{{ key|trans }}:</strong> {{ byKey[key] }}
                </span>
            {% endfor %}
        </div>
    {% endif %}
{% endmacro %}

{% macro area_filter_badges(filters, states) %}
    {% set rawFilters = [] %}

    {# --- Search term --- #}
    {% if filters.search is not empty %}
        {% set rawFilters = rawFilters|merge([{
            key: 'label.search',
            value: filters.search,
        }]) %}
    {% endif %}

    {# --- Lookup: State (id → name) --- #}
    {% if filters.state is not null %}
        {% set stateName = null %}
        {% for s in states %}
            {% if stateName is null and s.id == filters.state %}
                {% set stateName = s.name %}
            {% endif %}
        {% endfor %}
        {% if stateName is not null %}
            {% set rawFilters = rawFilters|merge([{
                key: 'label.state',
                value: stateName,
            }]) %}
        {% endif %}
    {% endif %}

    {# 2. Manual alphabetical sort (same pattern as before) #}
    {% set byKey = {} %}
    {% for f in rawFilters %}
        {% set byKey = byKey|merge({(f.key): f.value}) %}
    {% endfor %}

    {% set sortedKeys = byKey|keys|sort %}

    {# 3. Render badges #}
    {% if sortedKeys is not empty %}
        <div class="d-flex flex-wrap gap-1">
            {% for key in sortedKeys %}
                <span class="badge bg-blue-lt">
                    <strong>{{ key|trans }}:</strong> {{ byKey[key] }}
                </span>
            {% endfor %}
        </div>
    {% endif %}
{% endmacro %}

{% macro import_filter_badges(filters, hospitals, owners) %}
    {% set rawFilters = [] %}

    {% if filters.search is not empty %}
        {% set rawFilters = rawFilters|merge([{
            key: 'label.search',
            value: filters.search,
        }]) %}
    {% endif %}

    {% if filters.hospitalId is not null %}
        {% set hospitalName = null %}
        {% for hospital in hospitals %}
            {% if hospitalName is null and hospital.id == filters.hospitalId %}
                {% set hospitalName = hospital.name %}
            {% endif %}
        {% endfor %}
        {% if hospitalName is not null %}
            {% set rawFilters = rawFilters|merge([{
                key: 'label.hospital',
                value: hospitalName,
            }]) %}
        {% endif %}
    {% endif %}

    {% if filters.ownerId is not null %}
        {% set ownerName = null %}
        {% for owner in owners %}
            {% if ownerName is null and owner.id == filters.ownerId %}
                {% set ownerName = owner.username %}
            {% endif %}
        {% endfor %}
        {% if ownerName is not null %}
            {% set rawFilters = rawFilters|merge([{
                key: 'label.import.filter.owner',
                value: ownerName,
            }]) %}
        {% endif %}
    {% endif %}

    {% if filters.status is not empty %}
        {% set rawFilters = rawFilters|merge([{
            key: 'label.status',
            value: filters.status,
        }]) %}
    {% endif %}

    {% if filters.createdFrom is not empty and not filters.isDefaultCreatedFrom %}
        {% set rawFilters = rawFilters|merge([{
            key: 'label.import.filter.created_from',
            value: filters.createdFrom|date('d.m.Y'),
        }]) %}
    {% endif %}

    {% if filters.createdUntil is not empty and not filters.isDefaultCreatedUntil %}
        {% set rawFilters = rawFilters|merge([{
            key: 'label.import.filter.created_until',
            value: filters.createdUntil|date('d.m.Y'),
        }]) %}
    {% endif %}

    {% set byKey = {} %}
    {% for f in rawFilters %}
        {% set byKey = byKey|merge({(f.key): f.value}) %}
    {% endfor %}

    {% set sortedKeys = byKey|keys|sort %}

    {% if sortedKeys is not empty %}
        <div class="d-flex flex-wrap gap-1">
            {% for key in sortedKeys %}
                <span class="badge bg-blue-lt">
                    <strong>{{ key|trans }}:</strong> {{ byKey[key] }}
                </span>
            {% endfor %}
        </div>
    {% endif %}
{% endmacro %}

{% macro hospital_filter_badges(filters, states, dispatchAreas) %}
    {% set rawFilters = [] %}

    {# --- Search term --- #}
    {% if filters.search is not empty %}
        {% set rawFilters = rawFilters|merge([{
            key: 'label.search',
            value: filters.search,
        }]) %}
    {% endif %}

    {# --- Simple string filters --- #}
    {% if filters.tier is not empty %}
        {% set rawFilters = rawFilters|merge([{
            key: 'label.tier',
            value: filters.tier,
        }]) %}
    {% endif %}

    {% if filters.location is not empty %}
        {% set rawFilters = rawFilters|merge([{
            key: 'label.location',
            value: filters.location,
        }]) %}
    {% endif %}

    {% if filters.size is not empty %}
        {% set rawFilters = rawFilters|merge([{
            key: 'label.size',
            value: filters.size,
        }]) %}
    {% endif %}

    {# --- Lookup: Dispatch Area (id → name) --- #}
    {% if filters.dispatchArea is not null %}
        {% set areaName = null %}
        {% for a in dispatchAreas %}
            {% if areaName is null and a.id == filters.dispatchArea %}
                {% set areaName = a.name %}
            {% endif %}
        {% endfor %}
        {% if areaName is not null %}
            {% set rawFilters = rawFilters|merge([{
                key: 'label.dispatch_area',
                value: areaName,
            }]) %}
        {% endif %}
    {% endif %}

    {# --- Lookup: State (id → name) --- #}
    {% if filters.state is not null %}
        {% set stateName = null %}
        {% for s in states %}
            {% if stateName is null and s.id == filters.state %}
                {% set stateName = s.name %}
            {% endif %}
        {% endfor %}
        {% if stateName is not null %}
            {% set rawFilters = rawFilters|merge([{
                key: 'label.state',
                value: stateName,
            }]) %}
        {% endif %}
    {% endif %}

    {# --- Boolean-like filters --- #}
    {% if filters.participating is not null %}
        {% set rawFilters = rawFilters|merge([{key: 'label.participation', value: filters.participating ? 'Yes' : 'No'}]) %}
    {% endif %}

    {# 2. Manual alphabetical sort by label-translation-key #}
    {% set byKey = {} %}
    {% for f in rawFilters %}
        {% set byKey = byKey|merge({(f.key): f.value}) %}
    {% endfor %}

    {% set sortedKeys = byKey|keys|sort %}

    {# 3. Render badges #}
    {% if sortedKeys is not empty %}
        <div class="d-flex flex-wrap gap-1">
            {% for key in sortedKeys %}
                <span class="badge bg-blue-lt">
                    <strong>{{ key|trans }}:</strong> {{ byKey[key] }}
                </span>
            {% endfor %}
        </div>
    {% endif %}
{% endmacro %}
