{%- set fg = '#4b5563' -%}
{%- set fgHeading = '#111827' -%}
{%- set link = '#066FD1' -%}
{%- set boxBg = '#ffffff' -%}
{%- set pageBg = '#f9fafb' -%}
{%- set quoteBg = '#fafafa' -%}
{%- set border = '#e8ebee' -%}
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="color-scheme" content="light dark"/>
    <meta name="supported-color-schemes" content="light dark"/>
    <title>{{ 'feedback.email.title'|trans }}</title>
</head>
<body style="margin:0;padding:0;background-color:{{ pageBg }};font-family:Inter,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;font-size:15px;line-height:1.6;color:{{ fg }};-webkit-font-smoothing:antialiased;">
<center role="presentation" style="width:100%;background-color:{{ pageBg }};">
    <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;max-width:560px;width:100%;border-collapse:collapse;">
        <tr>
            <td style="padding:40px 16px;">
                <div style="background:{{ boxBg }};border:1px solid {{ border }};border-radius:8px;box-shadow:0 1px 4px rgba(0,0,0,0.05);">
                    <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;">
                        <tr>
                            <td align="center" style="padding:40px 32px 0;">
                                <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;border-collapse:separate;background-color:{{ link }};width:56px;height:56px;border-radius:50%;line-height:100%;">
                                    <tr>
                                        <td align="center" valign="middle" style="padding:12px;color:#ffffff;font-size:26px;line-height:1;">&#9993;</td>
                                    </tr>
                                </table>
                                <h1 style="margin:16px 0 0;text-align:center;font-size:26px;line-height:1.26;color:{{ fgHeading }};font-weight:600;">
                                    {{ 'feedback.email.heading'|trans }}
                                </h1>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:32px;">
                                <div style="font-size:13px;line-height:1.5;color:{{ fg }};margin-bottom:16px;">
                                    <strong style="font-weight:600;color:{{ fgHeading }};">{{ 'feedback.email.label.category'|trans }}:</strong>
                                    {{ categoryLabel }}<br/>
                                    <strong style="font-weight:600;color:{{ fgHeading }};">{{ 'feedback.email.label.from'|trans }}:</strong>
                                    {% set u = feedback.submittedBy %}
                                    {% if u is not null %}
                                        {{ 'feedback.email.actor.user'|trans({username: u.userIdentifier}) }}
                                        {% if u.email %} &lt;{{ u.email }}&gt;{% endif %}
                                    {% else %}
                                        {{ feedback.guestEmail|default('—') }}
                                    {% endif %}
                                    <br/>
                                    <strong style="font-weight:600;color:{{ fgHeading }};">{{ 'feedback.email.label.page'|trans }}:</strong>
                                    <a href="{{ feedback.pageUrl }}" style="color:{{ link }};text-decoration:none;">{{ feedback.pagePath }}</a><br/>
                                    <strong style="font-weight:600;color:{{ fgHeading }};">{{ 'feedback.email.label.route'|trans }}:</strong>
                                    {{ feedback.routeName|default('—') }}<br/>
                                    <strong style="font-weight:600;color:{{ fgHeading }};">{{ 'feedback.email.label.time'|trans }}:</strong>
                                    {{ feedback.createdAt|date('d.m.Y H:i', 'Europe/Berlin') }}
                                    {% if feedback.appVersion %}<br/>
                                        <strong style="font-weight:600;color:{{ fgHeading }};">{{ 'feedback.email.label.app_version'|trans }}:</strong>
                                        {{ feedback.appVersion }}
                                    {% endif %}
                                </div>
                                <div style="background-color:{{ quoteBg }};border-radius:8px;padding:14px 16px;display:inline-block;width:calc(100% - 32px);box-sizing:border-box;">
                                    <div style="font-weight:600;color:{{ fgHeading }};margin-bottom:8px;">{{ 'feedback.email.label.message'|trans }}</div>
                                    <p style="margin:0 0 12px;font-size:15px;line-height:1.6;white-space:pre-wrap;word-break:break-word;">{{ feedback.message|e('html') }}</p>
                                </div>
                                {% if feedback.userAgent %}
                                    <div style="margin-top:24px;font-size:12px;color:{{ fg }};">
                                        <strong style="font-weight:600;color:{{ fgHeading }};">User-Agent:</strong>
                                        {{ feedback.userAgent|e('html') }}
                                    </div>
                                {% endif %}
                                <pre style="margin-top:24px;background-color:#354258;color:#ffffff;padding:12px;border-radius:8px;font-size:12px;line-height:1.45;overflow:auto;white-space:pre-wrap;word-break:break-word;">{{ contextJson }}</pre>
                            </td>
                        </tr>
                    </table>
                </div>
                <div style="text-align:center;margin-top:20px;font-size:12px;color:#8491a1;">
                    {{ app_title|default('') }}
                </div>
            </td>
        </tr>
    </table>
</center>
</body>
</html>
