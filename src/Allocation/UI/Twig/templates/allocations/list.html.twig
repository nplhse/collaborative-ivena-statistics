{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'title.allocation.list'|trans }} - {{ parent() }}{% endblock %}

{% block turbo_drive %}data-turbo=true{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include(('@Shared/_includes/subnav_explore.html.twig')) }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs
            :items="[
                    { label: 'link.explore', path: path('app_explore_index') },
                    { label: 'title.allocation.list' }
                ]"
        />

        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    {% block page_intro %}
                        <h2 class="page-title">
                            {% block page_title %}{{ 'title.allocation.list'|trans }}{% endblock %}
                        </h2>
                        {% block page_subtitle %}
                            {% block result_count %}
                                <div id="result-count" class="text-body-secondary mt-1">
                                    {% if paginator.estimatedNumResults %}
                                        {% set estimatedResults = paginator.estimatedNumResults %}
                                        {% set estimatedPages = paginator.estimatedLastPage %}
                                        Showing approx. {{ estimatedResults|number_format(0, ',', '.') }}
                                        {{ estimatedResults == 1 ? 'result' : 'results' }}
                                        across {{ estimatedPages|number_format(0, ',', '.') }}
                                        {{ estimatedPages == 1 ? 'page' : 'pages' }}.
                                    {% else %}
                                        Showing results.
                                    {% endif %}
                                </div>
                            {% endblock %}
                        {% endblock %}
                    {% endblock %}
                </div>
                <!-- Page title actions -->
                <div class="col-auto ms-auto d-print-none">
                    <div class="btn-list">
                        {{ include('@Shared/_includes/_filter_drawer_trigger.html.twig', {
                            activeFilterCount: activeFilterCount,
                            drawerId: 'allocation-filters',
                            resetUrl: activeFilterCount > 0 ? path('app_explore_allocation_list') : null,
                        }) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    <turbo-frame id="allocation-list" data-turbo-action="advance">
        {% import '@Shared/_macros/filters.html.twig' as activeFilters %}

        {% if activeFilterCount > 0 %}
            <div class="alert alert-info" role="alert">
                <strong class="text-info">{{ 'label.filters.active'|trans }}:</strong>
                {{ activeFilters.allocation_filter_badges(filters, states, dispatchAreas, indications, secondaryTransports, infections, departments, specialities, transportTypes, hospitalScopeOptions) }}
            </div>
        {% endif %}

        <twig:DataTable
            :paginator="paginator"
            :paginationRoute="pagination_route"
            paginationTemplate="@Allocation/allocations/_cursor_pagination_footer.html.twig"
        >
            {% import '@Shared/_macros/pagination.html.twig' as pagination %}

            <table class="table data-table-card">
                <thead>
                <tr>
                    <th class="col-2">
                        <a class="text-muted" href="{{ path('app_explore_allocation_list', {
                            ...app.request.query.all(),
                            cursor: null,
                            sortBy: 'arrivalAt',
                            orderBy: sortBy == 'arrivalAt' and orderBy == 'asc' ? 'desc' : 'asc',
                        }) }}">
                            {{ 'label.timestamps'|trans }} {{ pagination.sortArrow('arrivalAt', sortBy, orderBy) }}
                        </a>
                    </th>
                    <th class="col-1">
                        <a class="text-muted" href="{{ path('app_explore_allocation_list', {
                            ...app.request.query.all(),
                            cursor: null,
                            sortBy: 'age',
                            orderBy: sortBy == 'age' and orderBy == 'asc' ? 'desc' : 'asc',
                        }) }}">
                            {{ 'label.age'|trans }} {{ pagination.sortArrow('age', sortBy, orderBy) }}
                        </a>
                    </th>
                    <th class="col-3">
                        {{ 'label.hospital'|trans }}
                    </th>
                    <th class="col-3">
                        {{ 'label.indication'|trans }}
                    </th>
                    <th class="col-1">
                        {{ 'label.urgency'|trans }}
                    </th>
                    <th class="col-1">
                        {{ 'label.properties'|trans }}
                    </th>
                    <th class="col-1">
                    </th>
                </tr>
                </thead>
                <tbody>
                {% for allocation in paginator.results %}
                    <tr>
                        <td>
                            <twig:ux:icon name="tabler:clock-play" class="w-3 h-3" /> {{ allocation.createdAt|date('d.m.Y H:i') }}<br/>
                            <twig:ux:icon name="tabler:clock-check" class="w-3 h-3" /> {{ allocation.arrivalAt|date('d.m.Y H:i') }}
                        </td>
                        <td>
                            {% if allocation.gender.value == 'M' %}
                                <twig:ux:icon name="tabler:gender-male" class="w-3 h-3" />
                            {% elseif allocation.gender.value == 'F' %}
                                <twig:ux:icon name="tabler:gender-female" class="w-3 h-3" />
                            {% else %}
                                <twig:ux:icon name="tabler:gender-agender" class="w-3 h-3" />
                            {% endif %}
                            {{ allocation.age }}
                        </td>
                        <td>
                            <a href="{{ path('app_explore_hospital_show', {id: allocation.hospital_id}) }}" target="_top">{{ allocation.hospital }}</a><br />
                            {{ allocation.dispatchArea }} - {{ allocation.state }}
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <div>
                                    {% if allocation.indicationNormalizedName is not null %}
                                        <span class="badge">{{ allocation.indicationNormalizedCode }}</span> <strong>{{ allocation.indicationNormalizedName }}</strong>
                                    {% else %}
                                        <span class="badge">{{ allocation.indicationRawCode }}</span> {{ allocation.indicationRawName }}
                                    {% endif %}
                                </div>
                                {% if allocation.secondaryIndicationRawName is not null %}
                                    <div>
                                        {% if allocation.secondaryIndicationNormalizedName is not null %}
                                            <span class="badge">{{ allocation.secondaryIndicationNormalizedCode }}</span> <strong class="fst-italic">{{ allocation.secondaryIndicationNormalizedName }}</strong>
                                        {% else %}
                                            <span class="badge bg-gray-500 text-white">{{ allocation.secondaryIndicationRawCode }}</span> <span class="fst-italic">{{ allocation.secondaryIndicationRawName }}</span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </td>
                        <td>
                            {% import '@Shared/_macros/badges.html.twig' as badges %}

                            {{ badges.render('allocation_urgency', allocation.urgency.value) }}
                        </td>
                        <td>
                            <span class="text-danger fw-bold">
                                {% if allocation.infection is not null %}
                                    <span class="badge bg-orange text-orange-fg">{{ allocation.infection }}</span>
                                {% endif %}
                                {% if allocation.requiresResus %}
                                    {{ 'S+'|trans }}
                                {% endif %}
                                {% if allocation.requiresCathlab %}
                                    {{ 'H+'|trans }}
                                {% endif %}
                                {% if allocation.isCPR %}
                                    {{ 'R+'|trans }}
                                {% endif %}
                                {% if allocation.isVentilated %}
                                    {{ 'B+'|trans }}
                                {% endif %}
                                {% if allocation.isWithPhysician %}
                                    {{ 'N+'|trans }}
                                {% endif %}
                                {% if allocation.isPregnant %}
                                    {{ 'label.pregnant'|trans }}
                                {% endif %}
                                {% if allocation.isWorkAccident %}
                                    {{ 'BG+'|trans }}
                                {% endif %}
                            </span>
                        </td>
                        <td>
                            <div class="btn-actions">
                                <a href="{{ path('app_explore_allocation_show', {id: allocation.id}) }}" class="btn btn-action" target="_top">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                        <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                            <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0-4 0"/>
                                            <path d="M21 12q-3.6 6-9 6t-9-6q3.6-6 9-6t9 6"/>
                                        </g>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">
                            <div class="empty">
                                <div class="empty-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                        <circle cx="12" cy="12" r="9" />
                                        <line x1="9" y1="10" x2="9.01" y2="10" />
                                        <line x1="15" y1="10" x2="15.01" y2="10" />
                                        <path d="M9.5 15.25a3.5 3.5 0 0 1 5 0" />
                                    </svg>
                                </div>
                                <p class="empty-title">{{ 'label.search_no_results'|trans }}</p>
                                <p class="empty-subtitle text-secondary">
                                    {{ 'help.search_no_results'|trans }}
                                </p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </twig:DataTable>

        <turbo-stream action="replace" target="result-count">
            <template>
                {{ block('result_count') }}
            </template>
        </turbo-stream>
    </turbo-frame>

    {{ include('@Allocation/allocations/_allocation_filter_drawer.html.twig') }}
{% endblock %}
