{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'title.mci_case.list'|trans }} - {{ parent() }}{% endblock %}

{% block turbo_drive %}data-turbo=true{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include(('@Shared/_includes/subnav_explore.html.twig')) }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs
            :items="[
                { label: 'link.explore', path: path('app_explore_index') },
                { label: 'title.mci_case.list'|trans }
            ]"
        />

        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    {% block page_intro %}
                        <h2 class="page-title">
                            {% block page_title %}{{ 'title.mci_case.list'|trans }}{% endblock %}
                        </h2>
                        {% block page_subtitle %}
                            {% block result_count %}
                                <div id="result-count" class="text-body-secondary mt-1">
                                    {{ 'label.pagination_numbers'|trans({first: paginator.firstResultNumber|number_format(0, ',', '.'), last: paginator.lastResultNumber|number_format(0, ',', '.'), total: paginator.numResults|number_format(0, ',', '.')}) }}
                                </div>
                            {% endblock %}
                        {% endblock %}
                    {% endblock %}
                </div>

                <div class="col-auto ms-auto d-print-none">
                    <div class="btn-list">
                        {% if importId is not null %}
                            <a class="btn btn-outline-secondary" href="{{ path('app_explore_mci_case_list') }}">
                                {{ 'label.filters.reset'|trans }}
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    <turbo-frame id="mci_case-list" data-turbo-action="advance">
        <twig:DataTable
            :paginator="paginator"
            :paginationRoute="pagination_route"
        >
            {% import '@Shared/_macros/pagination.html.twig' as pagination %}

            <table class="table data-table-card">
                <thead>
                <tr>
                    <th class="col-2">
                        <a class="text-muted" href="{{ path('app_explore_mci_case_list', {
                            ...app.request.query.all(),
                            sortBy: 'createdAt',
                            orderBy: sortBy == 'createdAt' and orderBy == 'asc' ? 'desc' : 'asc',
                        }) }}">
                            {{ 'label.timestamps'|trans }} {{ pagination.sortArrow('createdAt', sortBy, orderBy) }}
                        </a>
                    </th>
                    <th class="col-3">
                        {{ 'label.hospital'|trans }}
                    </th>
                    <th class="col-3">
                        MCI Title
                    </th>
                    <th class="col-2">
                        {{ 'label.properties'|trans }}
                    </th>
                    <th class="col-1"></th>
                </tr>
                </thead>
                <tbody>
                {% for mciCase in paginator.results %}
                    <tr>
                        <td>
                            <twig:ux:icon name="tabler:clock-play" class="w-3 h-3" /> {{ mciCase.createdAt|date('d.m.Y H:i') }}<br/>
                            <twig:ux:icon name="tabler:clock-check" class="w-3 h-3" /> {{ mciCase.arrivalAt|date('d.m.Y H:i') }}
                        </td>
                        <td>
                            <a href="{{ path('app_explore_hospital_show', {id: mciCase.hospital_id}) }}" target="_top">{{ mciCase.hospital }}</a><br/>
                            {{ mciCase.dispatchArea }} - {{ mciCase.state }}
                        </td>
                        <td>
                            <strong>{{ mciCase.mciTitle }}</strong><br/>
                            <span class="text-muted">{{ mciCase.mciId }}</span>
                        </td>
                        <td>
                            <span class="text-danger fw-bold">
                                {% if mciCase.requiresResus is same as true %}{{ 'S+'|trans }}{% endif %}
                                {% if mciCase.requiresCathlab is same as true %} {{ 'H+'|trans }}{% endif %}
                                {% if mciCase.isCPR is same as true %} {{ 'R+'|trans }}{% endif %}
                                {% if mciCase.isVentilated is same as true %} {{ 'B+'|trans }}{% endif %}
                                {% if mciCase.isShock is same as true %} Shock{% endif %}
                                {% if mciCase.isWithPhysician is same as true %} {{ 'N+'|trans }}{% endif %}
                                {% if mciCase.isPregnant is same as true %} {{ 'label.pregnant'|trans }}{% endif %}

                                {% if mciCase.requiresResus is not same as true and mciCase.requiresCathlab is not same as true and mciCase.isCPR is not same as true and mciCase.isVentilated is not same as true and mciCase.isShock is not same as true and mciCase.isWithPhysician is not same as true and mciCase.isPregnant is not same as true %}
                                    —
                                {% endif %}
                            </span>
                        </td>
                        <td>
                            <div class="btn-actions">
                                <a href="{{ path('app_explore_mci_case_show', {id: mciCase.id}) }}" class="btn btn-action" target="_top">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                        <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                            <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0-4 0"/>
                                            <path d="M21 12q-3.6 6-9 6t-9-6q3.6-6 9-6t9 6"/>
                                        </g>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">
                            <div class="empty">
                                <div class="empty-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                        <circle cx="12" cy="12" r="9" />
                                        <line x1="9" y1="10" x2="9.01" y2="10" />
                                        <line x1="15" y1="10" x2="15.01" y2="10" />
                                        <path d="M9.5 15.25a3.5 3.5 0 0 1 5 0" />
                                    </svg>
                                </div>
                                <p class="empty-title">{{ 'label.search_no_results'|trans }}</p>
                                <p class="empty-subtitle text-secondary">
                                    {{ 'help.search_no_results'|trans }}
                                </p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </twig:DataTable>

        <turbo-stream action="replace" target="result-count">
            <template>
                {{ block('result_count') }}
            </template>
        </turbo-stream>
    </turbo-frame>
{% endblock %}
