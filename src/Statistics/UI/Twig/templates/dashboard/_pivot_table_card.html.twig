{# @var widget \App\Statistics\Application\DTO\StatisticWidget #}
{% set p = widget.payload %}
<div class="card" data-testid="stats-analysis-pivot-table-card">
    {% if p.pivotRowChoices is defined and p.pivotColChoices is defined %}
        <div class="card-body border-bottom py-3">
            {{ include('@Statistics/analysis/_pivot_selector_group.html.twig', {
                pivotRowChoices: p.pivotRowChoices,
                pivotColChoices: p.pivotColChoices,
                pivotMeasureChoices: p.pivotMeasureChoices|default([]),
            }) }}
        </div>
    {% endif %}
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-striped">
                <thead>
                    <tr>
                        <th scope="col">{{ p.rowDimensionLabel }}</th>
                        {% for colLabel in p.columnLabels %}
                            <th scope="col" class="text-end">{{ colLabel }}</th>
                        {% endfor %}
                        {% if p.showTotals|default(true) %}
                            <th scope="col" class="text-end">{{ p.rowTotalHeaderLabel }}</th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for rowLabel in p.rowLabels %}
                        <tr>
                            <th scope="row">{{ rowLabel }}</th>
                            {% for v in p.matrix[loop.index0] %}
                                <td class="text-end">{{ v }}</td>
                            {% endfor %}
                            {% if p.showTotals|default(true) %}
                                <td class="text-end fw-semibold">{{ p.row_totals[loop.index0] }}</td>
                            {% endif %}
                        </tr>
                    {% endfor %}
                </tbody>
                {% if p.columnLabels is not empty and p.showTotals|default(true) %}
                    <tfoot class="table-light">
                        <tr>
                            <th scope="row">{{ p.columnTotalFooterLabel }}</th>
                            {% for v in p.column_totals %}
                                <td class="text-end fw-semibold">{{ v }}</td>
                            {% endfor %}
                            <td class="text-end fw-bold">{{ p.grand_total }}</td>
                        </tr>
                    </tfoot>
                {% endif %}
            </table>
        </div>
    </div>
</div>
