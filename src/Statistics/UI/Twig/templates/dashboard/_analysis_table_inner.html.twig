{# Table body content like _table_card card-body (without outer card wrapper) #}
{% set p = tablePayload %}
{% set numericStart = p.numericColumnStartIndex ?? 2 %}
{% set summaryTestId = tableSummaryTestId|default('stats-analysis-table-summary') %}
{% if p.rows is defined and p.rows is not empty %}
    {% if p.summaryStats is defined %}
        <p class="text-secondary small mb-3" data-testid="{{ summaryTestId }}">
            <span class="text-body">{{ 'stats.analysis.table.summary_mean_label'|trans }}</span>
            {{ p.summaryStats.meanDisplay }}
            <span class="mx-1">·</span>
            <span class="text-body">{{ 'stats.analysis.table.summary_std_label'|trans }}</span>
            {{ p.summaryStats.stdDevDisplay }}
        </p>
    {% endif %}
    <div class="table-responsive">
        <table class="table table-vcenter card-table table-striped mb-0">
            <thead>
                <tr>
                    {% for hk in p.headerTranslationKeys %}
                        <th class="{{ loop.index < numericStart ? '' : 'text-end' }}">{{ hk|trans }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for row in p.rows %}
                    {% set monthRowTarget = null %}
                    {% if p.monthRowTargets is defined %}
                        {% set monthRowTarget = p.monthRowTargets[loop.index0]|default(null) %}
                    {% endif %}
                    {% set diagnosisRowTarget = null %}
                    {% if p.diagnosisRowTargets is defined %}
                        {% set diagnosisRowTarget = p.diagnosisRowTargets[loop.index0]|default(null) %}
                    {% endif %}
                    <tr>
                        {% for cell in row %}
                            <td class="{{ loop.index < numericStart ? '' : 'text-end' }}">
                                {% if loop.first and monthRowTarget is defined and monthRowTarget is not null %}
                                    <a href="{{ statistics_nav_url(monthRowTarget) }}" class="text-reset">{{ cell }}</a>
                                {% elseif loop.index == 2 and diagnosisRowTarget is not null %}
                                    <a href="{{ statistics_nav_url(diagnosisRowTarget) }}" class="text-reset">{{ cell }}</a>
                                {% else %}
                                    {{ cell }}
                                {% endif %}
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>
            {% if p.footerRow is defined %}
                <tfoot class="table-light">
                    {% if p.footerRow.counts is defined %}
                        <tr>
                            <th>{{ p.footerRow.labelTranslationKey|trans }}</th>
                            {% for c in p.footerRow.counts %}
                                <th class="text-end">{{ c }}</th>
                            {% endfor %}
                        </tr>
                    {% else %}
                        <tr>
                            <th>{{ p.footerRow.labelTranslationKey|trans }}</th>
                            <th class="text-end">{{ p.footerRow.count }}</th>
                            <th class="text-end">{{ p.footerRow.percentDisplay }}</th>
                        </tr>
                    {% endif %}
                </tfoot>
            {% endif %}
        </table>
    </div>
{% else %}
    <p class="text-muted mb-0">{{ 'stats.overview.table.placeholder'|trans }}</p>
{% endif %}
