{# targets: list<StatisticWidgetNavigationTarget>; optional primary_test_id for functional tests #}
{% if targets is defined and targets is not empty %}
    <div class="card-actions ms-auto">
        {% for t in targets %}
            {% if t.labelTranslationKey is not empty %}
                <a href="{{ statistics_nav_url(t) }}"
                   class="btn btn-sm btn-link px-2 py-1"
                   {% if loop.first and primary_test_id is defined %}data-testid="{{ primary_test_id }}"{% endif %}
                   {% if loop.index == 2 and secondary_test_id is defined %}data-testid="{{ secondary_test_id }}"{% endif %}
                   {% if loop.index == 3 and tertiary_test_id is defined %}data-testid="{{ tertiary_test_id }}"{% endif %}>
                    {{ t.labelTranslationKey|trans({}, 'statistics') }}
                </a>
            {% endif %}
        {% endfor %}
    </div>
{% endif %}
