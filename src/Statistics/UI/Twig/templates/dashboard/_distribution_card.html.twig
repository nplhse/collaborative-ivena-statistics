{# @var widget \App\Statistics\Application\DTO\StatisticWidget #}
{% set p = widget.payload %}
<div class="card" data-testid="{{ p.testId|default('stats-overview-indicators') }}">
    <div class="card-header py-2">
        {{ include('@Statistics/dashboard/_linked_card_title.html.twig', {
            link: widget.actions[0] ?? null,
            test_id: p.actionTestId|default('stats-cross-nav-overview-indicators'),
            title: p.titleTranslationKey,
        }) }}
    </div>
    <div class="card-body">
        {% for row in p.rows %}
            <div class="mb-2{% if loop.last %} mb-0{% endif %}">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span>{{ row.labelTranslationKey|trans }}</span>
                    <span class="text-muted">{{ row.count|number_format(0, ',', '.') }}&nbsp;&nbsp;{{ (row.percent|default(0))|number_format(1, '.', '') }}%</span>
                </div>
                <div class="progress progress-sm">
                    <div class="progress-bar"
                         style="width: {{ row.percent|default(0) }}%"
                         role="progressbar"
                         aria-valuenow="{{ row.percent|default(0) }}"
                         aria-valuemin="0"
                         aria-valuemax="100"></div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
