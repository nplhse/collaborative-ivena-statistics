{# @var statisticsFilter \App\Statistics\Application\DTO\StatisticsFilter #}
{% set showHospitalCol = isLoggedIn and accessibleHospitals is not empty and statisticsFilter.scope.value != 'public' %}
{% set noHospitalsForUser = isLoggedIn and accessibleHospitals is empty %}
{% set scopePublicActive = statisticsFilter.scope.value == 'public' or (noHospitalsForUser and statisticsFilter.scope.value == 'my_hospitals') %}

<div class="card mb-0" data-testid="stats-filter-bar">
    <div class="card-body">
        <div class="subheader mb-2">{{ 'stats.filter.scope_label'|trans }}</div>
        <div class="list-group list-group-transparent mb-4">
            <a href="{{ statsScopeUrls.public }}"
               class="list-group-item list-group-item-action d-flex align-items-center{% if scopePublicActive %} active{% endif %}">
                {{ 'stats.filter.scope.public'|trans }}
            </a>
            {% if isLoggedIn and accessibleHospitals is not empty %}
                <a href="{{ statsScopeUrls.my_hospitals }}"
                   class="list-group-item list-group-item-action d-flex align-items-center{% if statisticsFilter.scope.value == 'my_hospitals' or statisticsFilter.scope.value == 'hospital' %} active{% endif %}">
                    {% if accessibleHospitals|length == 1 %}
                        {{ 'stats.filter.hospital.my_hospital'|trans }}
                    {% else %}
                        {{ 'stats.filter.scope.my_hospitals'|trans }}
                    {% endif %}
                </a>
            {% endif %}
        </div>

        {% if showHospitalCol and accessibleHospitals|length > 1 %}
            <div class="subheader mb-2">{{ 'stats.filter.hospital_label'|trans }}</div>
            <div class="dropdown mb-4">
                <button type="button"
                        class="btn btn-secondary dropdown-toggle w-100 d-flex align-items-center justify-content-between text-start gap-2"
                        data-bs-toggle="dropdown"
                        aria-expanded="false">
                    <span class="flex-grow-1 min-w-0 text-break">
                        {% if statisticsFilter.scope.value == 'hospital' %}
                            {% if statsHospitalDropdownSelectedName %}
                                {{ statsHospitalDropdownSelectedName }}
                            {% else %}
                                {{ 'stats.filter.hospital.choose'|trans }}
                            {% endif %}
                        {% else %}
                            {{ 'stats.filter.hospital.all_hospitals'|trans }}
                        {% endif %}
                    </span>
                </button>
                <div class="dropdown-menu w-100">
                    <a class="dropdown-item text-wrap{% if statisticsFilter.scope.value == 'my_hospitals' %} active{% endif %}"
                       href="{{ statsScopeUrls.my_hospitals }}">
                        {{ 'stats.filter.hospital.all_hospitals'|trans }}
                    </a>
                    <div class="dropdown-divider"></div>
                    {% for hospital in accessibleHospitals %}
                        <a class="dropdown-item text-wrap text-break{% if statisticsFilter.scope.value == 'hospital' and statisticsFilter.hospitalId == hospital.id %} active{% endif %}"
                           href="{{ statsHospitalUrls[hospital.id] }}">
                            {{ hospital.name }}
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <div class="subheader mb-2">{{ 'stats.filter.period_label'|trans }}</div>
        <div class="list-group list-group-transparent">
            <a href="{{ statsPeriodUrls.all }}"
               class="list-group-item list-group-item-action d-flex align-items-center{% if statisticsFilter.period.value == 'all' %} active{% endif %}">
                {{ 'stats.filter.period.all'|trans }}
            </a>
            <a href="{{ statsPeriodUrls.all_time }}"
               class="list-group-item list-group-item-action d-flex align-items-center{% if statisticsFilter.period.value == 'all_time' %} active{% endif %}">
                {{ 'stats.filter.period.all_time'|trans }}
            </a>
            <a href="{{ statsPeriodUrls.year }}"
               class="list-group-item list-group-item-action d-flex align-items-center{% if statisticsFilter.period.value == 'year' %} active{% endif %}">
                {{ 'stats.filter.period.year'|trans }}
            </a>
            <a href="{{ statsPeriodUrls.month }}"
               class="list-group-item list-group-item-action d-flex align-items-center{% if statisticsFilter.period.value == 'month' %} active{% endif %}">
                {{ 'stats.filter.period.month'|trans }}
            </a>
        </div>
    </div>
</div>
