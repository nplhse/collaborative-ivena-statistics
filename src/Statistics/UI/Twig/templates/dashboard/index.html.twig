{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}Overview: {{ statisticsHeadingScope }} · {{ statisticsHeadingPeriod }} – {{ parent() }}{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include(('@Shared/_includes/subnav_stats.html.twig')) }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs :items="[
            { label: 'link.statistics', path: path('app_stats_dashboard') },
            { label: 'link.stats.dashboard' }
        ]" />

        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle" data-testid="stats-heading-scope">
                        {{ statisticsHeadingScope }}
                    </div>
                    <h2 class="page-title" data-testid="stats-heading-period">
                        {{ statisticsHeadingPeriod }}
                    </h2>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    <div class="row g-4 align-items-start">
        <aside class="col-12 col-lg-3 col-xl-2">
            <div class="position-lg-sticky" style="top: 1rem;">
                {{ include('@Statistics/dashboard/_statistics_filter_bar.html.twig') }}
            </div>
        </aside>
        <div class="col-12 col-lg-9 col-xl-10 min-w-0">
            <div data-testid="stats-hospital-summary">
                {% for widget in hospitalSummaryWidgets %}
                    {{ include('@Statistics/dashboard/_statistic_widget.html.twig', {widget: widget}) }}
                {% endfor %}
            </div>

            {% set resourcesWidget = null %}
            {% set featuresWidget = null %}
            {% for widget in clinicalFeatureWidgets %}
                {% if widget.id == 'clinical_resources_distribution' %}
                    {% set resourcesWidget = widget %}
                {% elseif widget.id == 'clinical_features_distribution' %}
                    {% set featuresWidget = widget %}
                {% endif %}
            {% endfor %}

            {% if chartPairWidget is not null %}
                {% set p = chartPairWidget.payload %}
                <div class="row g-3 mt-1"
                     data-testid="stats-charts"
                     data-controller="dashboard-charts"
                     data-dashboard-charts-allocations-value="{{ p.allocationChart|json_encode|e('html_attr') }}"
                     data-dashboard-charts-imports-value="{{ p.importChart|json_encode|e('html_attr') }}">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-body">
                                <h3 class="card-title mb-0">Allocations</h3>
                                <div data-dashboard-charts-target="allocationsChart" class="chart-lg"></div>
                            </div>
                        </div>
                        <div class="card mt-3">
                            <div class="card-body">
                                <h3 class="card-title mb-0">Imports</h3>
                                <div data-dashboard-charts-target="importsChart" class="chart-lg"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        {% if resourcesWidget is not null %}
                            {{ include('@Statistics/dashboard/_statistic_widget.html.twig', {widget: resourcesWidget}) }}
                        {% endif %}
                        {% if featuresWidget is not null %}
                            {{ include('@Statistics/dashboard/_statistic_widget.html.twig', {widget: featuresWidget}) }}
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
