{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}Overview – {{ parent() }}{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include(('@Shared/_includes/subnav_stats.html.twig')) }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <div class="d-flex align-items-start justify-content-between gap-3">
            <twig:Breadcrumbs :items="[
                { label: 'link.statistics', path: path('app_stats_dashboard') },
                { label: 'link.stats.dashboard' }
            ]" />

            <div class="flex-shrink-0 d-print-none mt-2">
                {{ include('@Statistics/_data_quality_indicator.html.twig') }}
            </div>
        </div>

        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle" data-testid="stats-heading-subtitle">
                        {{ 'stats.overview.pretitle'|trans({}, 'statistics') }}
                    </div>
                    <h2 class="page-title" data-testid="stats-heading-title">
                        {{ 'link.stats.dashboard'|trans({}, 'shared') }}
                    </h2>
                </div>
                {{ include('@Statistics/_header_controls.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    {{ include('@Statistics/_data_quality_drawer.html.twig') }}

    <div class="row g-4 align-items-start">
        <div class="col-12 min-w-0" data-testid="stats-executive-dashboard">
            <div data-testid="stats-hospital-summary">
                {% for widget in hospitalSummaryWidgets %}
                    {{ include('@Statistics/dashboard/_widget_renderer.html.twig', {widget: widget}) }}
                {% endfor %}
            </div>

            {% set resourcesWidget = null %}
            {% set featuresWidget = null %}
            {% for widget in clinicalFeatureWidgets %}
                {% if widget.id == 'clinical_resources_distribution' %}
                    {% set resourcesWidget = widget %}
                {% elseif widget.id == 'clinical_features_distribution' %}
                    {% set featuresWidget = widget %}
                {% endif %}
            {% endfor %}

            <div class="row g-3 mt-1"
                 data-testid="stats-charts"
                 data-controller="indication-dashboard-charts"
                 data-indication-dashboard-charts-payload-value="{{ executiveDashboard.charts.chartPayload|json_encode|e('html_attr') }}">
                {{ include('@Statistics/dashboard/_overview_charts_main.html.twig') }}
                {{ include('@Statistics/dashboard/_overview_charts_sidebar.html.twig') }}
            </div>

            {% if overviewPeriodViewModel is defined %}
                {{ include('@Statistics/dashboard/_overview_period_navigation.html.twig') }}
            {% endif %}
        </div>
    </div>
{% endblock %}
