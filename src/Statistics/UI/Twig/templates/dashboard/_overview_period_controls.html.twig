{% set periodVm = overviewPeriodViewModel %}
{% set periodTestIdPrefix = periodTestIdPrefix|default('stats-period') %}
{% set usePicker = pickerMode|default(false) %}

<div class="btn-group" role="group" aria-label="{{ 'stats.filter.period_label'|trans({}, 'statistics') }}">
    {% if periodVm.showSecondaryPicker %}
        <div class="btn-group" role="group">
            <button type="button"
                    class="btn dropdown-toggle"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    data-testid="{{ periodTestIdPrefix }}-primary">
                {{ periodVm.primaryDropdownLabel }}
            </button>
            <div class="dropdown-menu">
                {% for item in periodVm.primaryMenu %}
                    <a class="dropdown-item{% if item.active %} active{% endif %}"
                       href="{{ item.url }}"
                       {% if usePicker %}data-action="benchmark-selection-picker#pickLink"{% endif %}>
                        {{ item.label }}
                    </a>
                {% endfor %}
            </div>
        </div>
        <div class="btn-group" role="group" data-controller="dropdown-typeahead">
            <button type="button"
                    class="btn dropdown-toggle"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    data-testid="{{ periodTestIdPrefix }}-secondary">
                {{ periodVm.secondaryDropdownLabel }}
            </button>
            <div class="dropdown-menu dropdown-menu-end dropdown-menu-scrollable" data-dropdown-typeahead-target="menu">
                {% for row in periodVm.secondaryMenu %}
                    {% if row.divider|default(false) %}
                        <div class="dropdown-divider"></div>
                    {% else %}
                        <a class="dropdown-item{% if row.active %} active{% endif %}"
                           href="{{ row.url }}"
                           {% if usePicker %}data-action="benchmark-selection-picker#pickLink"{% endif %}>
                            {{ row.label }}
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    {% else %}
        <div class="btn-group">
            <button type="button"
                    class="btn dropdown-toggle"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    data-testid="{{ periodTestIdPrefix }}-primary">
                {{ periodVm.primaryDropdownLabel }}
            </button>
            <div class="dropdown-menu dropdown-menu-end">
                {% for item in periodVm.primaryMenu %}
                    <a class="dropdown-item{% if item.active %} active{% endif %}"
                       href="{{ item.url }}"
                       {% if usePicker %}data-action="benchmark-selection-picker#pickLink"{% endif %}>
                        {{ item.label }}
                    </a>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>
