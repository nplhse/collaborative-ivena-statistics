<div class="row g-3 mb-4" data-testid="stats-executive-benchmark">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header py-2 d-flex justify-content-between align-items-center">
                <h3 class="card-title mb-0">{{ 'stats.overview.executive.section.benchmark'|trans }}</h3>
                <a href="{{ executiveDashboard.benchmarkingUrl }}" class="small">
                    {{ 'stats.overview.executive.benchmark.link'|trans }}
                </a>
            </div>
            <div class="card-body">
                {% if executiveDashboard.benchmarkInsufficientData %}
                    <p class="text-muted mb-0">{{ 'stats.overview.executive.benchmark.insufficient'|trans }}</p>
                {% else %}
                    <div class="row g-2">
                        {% for item in executiveDashboard.benchmarkScorecard %}
                            {% set statusClass = item.status == 'above' ? 'bg-orange-lt' : (item.status == 'below' ? 'bg-red-lt' : 'bg-green-lt') %}
                            <div class="col-sm-6">
                                <div class="border rounded p-3 h-100" data-testid="stats-executive-benchmark-{{ item.key }}">
                                    <div class="subheader small">{{ item.labelTranslationKey|trans }}</div>
                                    <div class="h3 mb-2">{{ item.displayValue }}</div>
                                    <span class="badge {{ statusClass }}">{{ item.statusLabelTranslationKey|trans }}</span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header py-2">
                <h3 class="card-title mb-0">{{ 'stats.overview.executive.section.deviations'|trans }}</h3>
            </div>
            <div class="card-body">
                {% if executiveDashboard.benchmarkInsufficientData or executiveDashboard.benchmarkSuppressRatios %}
                    <p class="text-muted mb-0">{{ 'stats.overview.executive.benchmark.insufficient'|trans }}</p>
                {% else %}
                    <p class="text-muted small mb-2">{{ 'stats.overview.executive.benchmark.positive'|trans }}</p>
                    <ul class="list-unstyled mb-3">
                        {% for deviation in executiveDashboard.benchmarkDeviations.positive %}
                            <li class="d-flex justify-content-between gap-2 mb-1">
                                <span>
                                    {% if deviation.url %}
                                        <a href="{{ deviation.url }}" class="text-reset">{{ deviation.label }}</a>
                                    {% else %}
                                        {{ deviation.label }}
                                    {% endif %}
                                </span>
                                <span class="badge bg-green-lt">{{ deviation.ratio|number_format(1, ',', '.') }}×</span>
                            </li>
                        {% else %}
                            <li class="text-muted">—</li>
                        {% endfor %}
                    </ul>
                    <p class="text-muted small mb-2">{{ 'stats.overview.executive.benchmark.negative'|trans }}</p>
                    <ul class="list-unstyled mb-0">
                        {% for deviation in executiveDashboard.benchmarkDeviations.negative %}
                            <li class="d-flex justify-content-between gap-2 mb-1">
                                <span>
                                    {% if deviation.url %}
                                        <a href="{{ deviation.url }}" class="text-reset">{{ deviation.label }}</a>
                                    {% else %}
                                        {{ deviation.label }}
                                    {% endif %}
                                </span>
                                <span class="badge bg-red-lt">{{ deviation.ratio|number_format(1, ',', '.') }}×</span>
                            </li>
                        {% else %}
                            <li class="text-muted">—</li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
</div>
