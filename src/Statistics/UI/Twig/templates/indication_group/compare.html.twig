{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ groupName }} – {{ 'stats.indication.group.compare_members'|trans }} – {{ parent() }}{% endblock %}

{% block page_content %}
    <div class="container-xl py-4">
        <twig:Breadcrumbs :items="[
            { label: 'link.statistics', path: path('app_stats_dashboard') },
            { label: 'link.stats.indication_insights', path: path('app_stats_indication_insights') },
            { label: groupName, path: path('app_stats_indication_group_dashboard', {groupId: groupId}) },
            { label: 'stats.indication.group.compare_members' }
        ]" />

        <h2 class="page-title mt-3 mb-4" data-testid="stats-indication-group-compare-title">{{ groupName }}</h2>

        <div class="card mb-3" data-testid="stats-indication-group-compare-table">
            <div class="card-header py-2">
                <h3 class="card-title mb-0">{{ 'stats.indication.group.members_title'|trans }}</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table mb-0">
                    <thead>
                        <tr>
                            <th>{{ 'stats.reports.table.diagnosis'|trans }}</th>
                            <th class="text-end">{{ 'stats.reports.table.count'|trans }}</th>
                            <th class="text-end">{{ 'stats.reports.table.share'|trans }}</th>
                            <th class="text-end">{{ 'stats.benchmark.metric.with_physician'|trans }}</th>
                            <th class="text-end">{{ 'stats.benchmark.metric.resus'|trans }}</th>
                            <th class="text-end">{{ 'stats.benchmark.metric.urgency_emergency'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in memberRows %}
                            <tr>
                                <td>{{ row.label }}</td>
                                <td class="text-end">{{ row.total|number_format(0, ',', '.') }}</td>
                                <td class="text-end">{{ row.shareWithinGroup|number_format(1, ',', '.') }}%</td>
                                <td class="text-end">{{ row.withPhysicianShare|number_format(1, ',', '.') }}%</td>
                                <td class="text-end">{{ row.resusShare|number_format(1, ',', '.') }}%</td>
                                <td class="text-end">{{ row.urgencyEmergencyShare|number_format(1, ',', '.') }}%</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if pairwiseLinks is not empty %}
            <div class="card" data-testid="stats-indication-group-pairwise-links">
                <div class="card-header py-2">
                    <h3 class="card-title mb-0">{{ 'stats.indication.compare.title'|trans }}</h3>
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    {% for link in pairwiseLinks %}
                        <a href="{{ link.url }}" class="text-reset">{{ link.labelA }} ↔ {{ link.labelB }}</a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
