{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ dashboard.header.indicationName }} – {{ 'stats.indication.group.dashboard.title'|trans }} – {{ parent() }}{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include('@Shared/_includes/subnav_stats.html.twig') }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <div class="d-flex align-items-start justify-content-between gap-3">
            <twig:Breadcrumbs :items="[
                { label: 'link.statistics', path: path('app_stats_dashboard') },
                { label: 'link.stats.indication_insights', path: path('app_stats_indication_insights') },
                { label: dashboard.header.indicationName }
            ]" />

            <div class="flex-shrink-0 d-print-none mt-2">
                {{ include('@Statistics/_data_quality_indicator.html.twig') }}
            </div>
        </div>

        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col min-w-0">
                    <div class="page-pretitle">{{ 'stats.indication.group.dashboard.title'|trans }}</div>
                    <h2 class="page-title mb-0" data-testid="stats-indication-group-heading-title">
                        {{ dashboard.header.indicationName }}
                    </h2>
                </div>
                {{ include('@Statistics/_header_controls.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    {{ include('@Statistics/_data_quality_drawer.html.twig') }}

    <div data-controller="indication-dashboard-charts"
         data-indication-dashboard-charts-payload-value="{{ chartPayload|json_encode|e('html_attr') }}">

        {{ include('@Statistics/indication_dashboard/_summary_deck.html.twig') }}

        <div class="mb-3 d-print-none d-flex gap-2 flex-wrap">
            <a href="{{ memberCompareUrl }}" class="btn btn-outline-primary" data-testid="stats-indication-group-compare-members">
                {{ 'stats.indication.group.compare_members'|trans }}
            </a>
        </div>

        {% if memberRows is not empty %}
            <div class="card mb-3" data-testid="stats-indication-group-members">
                <div class="card-header py-2">
                    <h3 class="card-title mb-0">{{ 'stats.indication.group.members_title'|trans }}</h3>
                </div>
                <div class="table-responsive">
                    <table class="table table-vcenter card-table mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'stats.reports.table.diagnosis'|trans }}</th>
                                <th class="text-end">{{ 'stats.reports.table.count'|trans }}</th>
                                <th class="text-end">{{ 'stats.reports.table.share'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in memberRows %}
                                <tr>
                                    <td>
                                        <a href="{{ path('app_stats_indication_dashboard', {indicationId: row.indicationId}) }}"
                                           class="link-body link-offset-2 link-underline link-underline-opacity-0 link-underline-opacity-100-hover">
                                            {{ row.label }}
                                        </a>
                                    </td>
                                    <td class="text-end">{{ row.total|number_format(0, ',', '.') }}</td>
                                    <td class="text-end">{{ row.shareWithinGroup|number_format(1, ',', '.') }}%</td>
                                    <td class="text-end">
                                        {% if row.compareUrl %}
                                            <a href="{{ row.compareUrl }}" class="btn btn-sm btn-outline-secondary">
                                                {{ 'stats.indication.compare.submit'|trans }}
                                            </a>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

        {{ include('@Statistics/indication_dashboard/_dashboard_charts.html.twig') }}
    </div>
{% endblock %}
