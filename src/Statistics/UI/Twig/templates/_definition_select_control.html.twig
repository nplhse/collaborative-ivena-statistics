{# expects: triggerId, labelKey, definitions, currentKey, selectUrls, selectedDescriptionKey? #}
<div class="col min-w-0">
    <label class="form-label mb-1" for="{{ triggerId }}">{{ labelKey|trans }}</label>
    <div class="dropdown w-100">
        <button id="{{ triggerId }}"
                class="btn btn-primary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
                type="button"
                data-bs-toggle="dropdown">
            {% for def in definitions %}
                {% if def.key == currentKey %}
                    {{ def.labelTranslationKey|trans }}
                {% endif %}
            {% endfor %}
        </button>
        <div class="dropdown-menu w-100">
            {% for def in definitions %}
                <a class="dropdown-item{% if def.key == currentKey %} active{% endif %}"
                   href="{{ selectUrls[def.key] }}">
                    {{ def.labelTranslationKey|trans }}
                </a>
            {% endfor %}
        </div>
    </div>
    {% if selectedDescriptionKey is defined and selectedDescriptionKey is not null %}
        <p class="text-secondary small mt-2 mb-0" data-testid="stats-reports-description">
            {{ selectedDescriptionKey|trans }}
        </p>
    {% endif %}
</div>
