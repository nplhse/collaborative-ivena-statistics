<div class="card mb-3"
     data-controller="hospital-population-map"
     data-hospital-population-map-payload-value="{{ mapPayload|json_encode|e('html_attr') }}"
     data-hospital-population-map-geo-url-value="{{ asset('geo/hessen-landkreise.geojson') }}"
     data-hospital-population-map-tier-label-value="{{ 'stats.hospital_population.table.tier'|trans|e('html_attr') }}"
     data-hospital-population-map-location-label-value="{{ 'stats.hospital_population.table.location'|trans|e('html_attr') }}"
     data-hospital-population-map-beds-label-value="{{ 'label.hospital_beds'|trans|e('html_attr') }}"
     data-hospital-population-map-all-hospitals-label-value="{{ 'stats.hospital_population.table.population'|trans|e('html_attr') }}"
     data-hospital-population-map-participants-label-value="{{ 'stats.hospital_population.table.participants'|trans|e('html_attr') }}"
     data-hospital-population-map-coverage-label-value="{{ 'stats.hospital_population.table.coverage'|trans|e('html_attr') }}"
     data-testid="stats-hospital-population-map">
    <div class="card-header py-2">
        <h3 class="card-title mb-0">{{ 'stats.hospital_population.section.map'|trans }}</h3>
    </div>
    <div class="card-body pt-2">
        <div class="case-flow-map-square">
            <div class="case-flow-map-container"
                 data-hospital-population-map-target="mapContainer"></div>
        </div>
        <div class="d-flex flex-wrap gap-3 text-muted small mt-2 align-items-center">
            <span class="d-inline-flex align-items-center gap-1">
                <svg class="hospital-population-map-legend-pin hospital-population-map-legend-pin--participating" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                    <path fill="currentColor" stroke="#ffffff" stroke-width="1.5" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                    <circle fill="#ffffff" cx="12" cy="9" r="2.5"/>
                </svg>
                {{ 'stats.hospital_population.map.legend_participants'|trans }}
            </span>
            <span class="d-inline-flex align-items-center gap-1">
                <svg class="hospital-population-map-legend-pin hospital-population-map-legend-pin--reference" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                    <path fill="currentColor" stroke="#ffffff" stroke-width="1.5" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                    <circle fill="#ffffff" cx="12" cy="9" r="2.5"/>
                </svg>
                {{ 'stats.hospital_population.map.legend_population'|trans }}
            </span>
        </div>
        <p class="text-secondary small mb-0 mt-2">{{ 'stats.hospital_population.map.legend_choropleth'|trans }}</p>
    </div>
</div>
