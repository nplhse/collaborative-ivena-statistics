{% import '@Statistics/hospital_population/_cross_table.html.twig' as crossTable %}

<div class="row g-3 mb-3" data-testid="stats-hospital-population-overview">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header py-2">
                <h3 class="card-title mb-0">{{ 'stats.hospital_population.section.regional_coverage'|trans({}, 'statistics') }}</h3>
            </div>
            <div
                id="hospital-population-regional-coverage"
                class="table-responsive"
                data-controller="hospital-population-regional-table"
            >
                <table class="table table-vcenter card-table">
                    <thead>
                        <tr>
                            <th><button class="table-sort" data-sort="sort-state">{{ 'stats.hospital_population.table.state'|trans({}, 'statistics') }}</button></th>
                            <th><button class="table-sort" data-sort="sort-dispatch-area">{{ 'stats.hospital_population.table.dispatch_area'|trans({}, 'statistics') }}</button></th>
                            <th class="text-end"><button class="table-sort" data-sort="sort-population">{{ 'stats.hospital_population.table.population'|trans({}, 'statistics') }}</button></th>
                            <th class="text-end"><button class="table-sort" data-sort="sort-participants">{{ 'stats.hospital_population.table.participants'|trans({}, 'statistics') }}</button></th>
                            <th class="text-end"><button class="table-sort" data-sort="sort-coverage">{{ 'stats.hospital_population.table.coverage'|trans({}, 'statistics') }}</button></th>
                        </tr>
                    </thead>
                    <tbody class="table-tbody">
                        {% for row in result.regionalCoverage %}
                            <tr>
                                <td class="sort-state">{{ row.stateName }}</td>
                                <td class="sort-dispatch-area">{{ row.dispatchAreaName }}</td>
                                <td class="sort-population text-end" data-population="{{ row.population }}">{{ row.population|number_format(0, ',', '.') }}</td>
                                <td class="sort-participants text-end" data-participants="{{ row.participants }}">{{ row.participants|number_format(0, ',', '.') }}</td>
                                <td class="sort-coverage text-end" data-coverage="{{ row.coverage|number_format(6, '.', '') }}">{{ crossTable.coverage_badge(row.coverage) }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-secondary">{{ 'stats.hospital_population.table.empty'|trans({}, 'statistics') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        {{ include('@Statistics/hospital_population/_map_card.html.twig') }}
        {{ crossTable.coverage_cross_table(
            'stats.hospital_population.section.location_by_tier'|trans({}, 'statistics'),
            'stats.hospital_population.table.tier'|trans({}, 'statistics'),
            'stats.hospital_population.table.location'|trans({}, 'statistics'),
            result.overview.urbanityByTierCrossTable,
        ) }}
        {{ crossTable.coverage_cross_table(
            'stats.hospital_population.section.size_by_tier'|trans({}, 'statistics'),
            'stats.hospital_population.table.tier'|trans({}, 'statistics'),
            'stats.hospital_population.table.size'|trans({}, 'statistics'),
            result.overview.sizeByTierCrossTable,
        ) }}
    </div>
</div>
