{% set page = customizePage %}

<div class="offcanvas offcanvas-end"
     tabindex="-1"
     id="analyticsCustomizeDrawer"
     aria-labelledby="analyticsCustomizeDrawerLabel"
     data-controller="analytics-customize-drawer generic-analysis-metrics"
     data-analytics-customize-drawer-title-with-series-template-value="{{ 'stats.generic_analysis.chart.subtitle_with_series'|trans({primary: '__PRIMARY__', series: '__SERIES__'}) }}"
     data-analytics-customize-drawer-title-without-series-template-value="{{ 'stats.analytics_library.save.title_draft'|trans({metric: '__METRIC__', primary: '__PRIMARY__'}) }}"
     data-testid="stats-analytics-customize-drawer">
    <div class="offcanvas-header">
        <h2 class="offcanvas-title" id="analyticsCustomizeDrawerLabel">
            {{ 'stats.analytics_library.customize_title'|trans }}
        </h2>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ 'action.close'|trans }}"></button>
    </div>
    <div class="offcanvas-body">
        {% if page.showRestrictedDimensionsHint %}
            <p class="text-secondary small mb-3">{{ 'stats.generic_analysis.restricted_dimensions_hint'|trans }}</p>
        {% endif %}

        <form method="get"
              action="{{ page.formAction }}"
              class="vstack gap-3"
              data-analytics-customize-drawer-target="customizeForm"
              data-testid="stats-analytics-customize-form">
            {% for field in page.preservedQueryFields %}
                <input type="hidden" name="{{ field.key }}" value="{{ field.value }}">
            {% endfor %}
            {% if page.formReferencePreset %}
                <input type="hidden" name="ga_ref" value="{{ page.formReferencePreset }}">
            {% endif %}
            <input type="hidden" name="ga_metrics[]" value="{{ page.defaultBaseMetricKey }}">

            {{ include('@Statistics/generic_analysis/_analysis_source_controls.html.twig', {
                page: page,
                idPrefix: 'drawer_',
                dataSourceStandaloneForm: true,
                populationStandaloneForm: true,
                populationTestId: 'stats-analytics-drawer-hospital-population',
            }) }}

            <div>
                <label class="form-label" for="drawer_ga_primary">{{ 'stats.generic_analysis.primary_dimension'|trans }}</label>
                <select class="form-select" id="drawer_ga_primary" name="ga_primary" required>
                    {% for group in page.dimensionGroups %}
                        <optgroup label="{{ group.label }}">
                            {% for option in group.options %}
                                <option value="{{ option.key }}"{% if option.key == page.formPrimary %} selected{% endif %}>
                                    {{ option.label }}
                                </option>
                            {% endfor %}
                        </optgroup>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label class="form-label" for="drawer_ga_series">{{ 'stats.generic_analysis.series_dimension'|trans }}</label>
                <select class="form-select" id="drawer_ga_series" name="ga_series">
                    <option value="">{{ 'stats.generic_analysis.series_none'|trans }}</option>
                    {% for group in page.dimensionGroups %}
                        <optgroup label="{{ group.label }}">
                            {% for option in group.options %}
                                <option value="{{ option.key }}"{% if option.key == page.formSeries %} selected{% endif %}>
                                    {{ option.label }}
                                </option>
                            {% endfor %}
                        </optgroup>
                    {% endfor %}
                </select>
            </div>

            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="drawer_ga_include_null" name="ga_include_null" value="1"
                       {% if page.formIncludeNull %}checked{% endif %}>
                <label class="form-check-label" for="drawer_ga_include_null">
                    {{ 'stats.generic_analysis.include_null_buckets'|trans }}
                </label>
            </div>

            <div>
                <span class="form-label d-block">{{ 'stats.generic_analysis.metrics_label'|trans }}</span>
                <div class="d-flex flex-wrap gap-2" data-generic-analysis-metrics-target="metricList">
                    {% for metric in page.availableMetrics %}
                        <div class="form-check">
                            {% if metric.key == page.defaultBaseMetricKey %}
                                <input class="form-check-input" type="checkbox" checked disabled>
                            {% else %}
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="ga_metrics[]"
                                       value="{{ metric.key }}"
                                       id="drawer_metric_{{ metric.key }}"
                                       {% if metric.selected %}checked{% endif %}
                                       {% if not metric.allowed %}disabled{% endif %}
                                       data-generic-analysis-metrics-target="metricCheckbox"
                                       data-action="change->generic-analysis-metrics#metricCheckboxChanged"
                                       data-metric-key="{{ metric.key }}"
                                       data-metric-label="{{ metric.label }}">
                            {% endif %}
                            <label class="form-check-label" for="drawer_metric_{{ metric.key }}">{{ metric.label }}</label>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div>
                <label class="form-label" for="drawer_ga_visual_metric">{{ 'stats.generic_analysis.visual_metric'|trans }}</label>
                <select class="form-select" id="drawer_ga_visual_metric" name="ga_visual_metric" data-generic-analysis-metrics-target="visualSelect">
                    {% for option in page.visualMetricOptions %}
                        <option value="{{ option.key }}"{% if option.selected %} selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label class="form-label" for="drawer_ga_series_mode">{{ 'stats.generic_analysis.series_mode_label'|trans }}</label>
                <select class="form-select" id="drawer_ga_series_mode" name="ga_series_mode">
                    {% for option in page.seriesModeOptions %}
                        <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label class="form-label" for="drawer_ga_chart">{{ 'stats.generic_analysis.chart.type_selector_label'|trans }}</label>
                <select class="form-select" id="drawer_ga_chart" name="ga_chart">
                    <option value="">{{ 'stats.generic_analysis.chart.type_recommended'|trans }}</option>
                    {% for option in page.chartTypeOptions %}
                        <option value="{{ option.value }}"{% if option.value == page.formChartType %} selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label class="form-label" for="drawer_ga_display">{{ 'stats.generic_analysis.display_mode_label'|trans }}</label>
                <select class="form-select" id="drawer_ga_display" name="ga_display">
                    {% for option in page.displayModeOptions %}
                        <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">{{ 'stats.analytics_library.apply'|trans }}</button>
                {% if page.resetToPresetUrl %}
                    <a href="{{ page.resetToPresetUrl }}" class="btn btn-outline-secondary">{{ 'stats.analytics_library.reset'|trans }}</a>
                {% endif %}
            </div>
        </form>

        {% if isLoggedIn and saveViewUrl %}
            <hr class="my-4">
            <h3 class="h5">{{ 'stats.analytics_library.save_as_title'|trans }}</h3>
            <form method="post" action="{{ saveViewUrl }}" class="vstack gap-2">
                <input type="hidden" name="_token" value="{{ csrf_token('analytics_save_view') }}">
                <input type="hidden" name="source_view_key" value="{{ viewKey }}">
                <input type="hidden" name="primary_dimension" value="{{ page.formPrimary }}" data-analytics-customize-drawer-target="savePrimary">
                <input type="hidden" name="secondary_dimension" value="{{ page.formSeries }}" data-analytics-customize-drawer-target="saveSeries">
                <input type="hidden" name="include_null" value="{{ page.formIncludeNull ? '1' : '0' }}" data-analytics-customize-drawer-target="saveIncludeNull">
                <input type="hidden" name="visual_metric" value="{{ page.formVisualMetric }}" data-analytics-customize-drawer-target="saveVisualMetric">
                <input type="hidden" name="series_mode" value="{{ page.formSeriesMode }}">
                <input type="hidden" name="display_mode" value="{{ page.formDisplayMode }}">
                <input type="hidden" name="chart_type" value="{{ page.formChartType }}">
                <div data-analytics-customize-drawer-target="saveMetrics">
                    {% for metric in page.availableMetrics %}
                        {% if metric.selected and metric.key != page.defaultBaseMetricKey %}
                            <input type="hidden" name="metrics[]" value="{{ metric.key }}">
                        {% endif %}
                    {% endfor %}
                </div>
                <div>
                    <label class="form-label" for="save_view_title">{{ 'stats.analytics_library.save.title_label'|trans }}</label>
                    <input type="text"
                           class="form-control"
                           id="save_view_title"
                           name="title"
                           value="{{ page.saveTitleDraft }}"
                           required
                           data-analytics-customize-drawer-target="titleInput"
                           data-action="input->analytics-customize-drawer#titleInputEdited"
                           data-testid="stats-analytics-save-view-title">
                </div>
                <div>
                    <label class="form-label" for="save_view_description">{{ 'stats.analytics_library.save.description_label'|trans }}</label>
                    <textarea class="form-control" id="save_view_description" name="description" rows="2"></textarea>
                </div>
                <button type="submit" class="btn btn-outline-primary" data-testid="stats-analytics-save-view">
                    {{ 'stats.analytics_library.save.submit'|trans }}
                </button>
            </form>
        {% else %}
            <p class="text-secondary small mt-4 mb-0">{{ 'stats.analytics_library.login_required_save'|trans }}</p>
        {% endif %}
    </div>
</div>
