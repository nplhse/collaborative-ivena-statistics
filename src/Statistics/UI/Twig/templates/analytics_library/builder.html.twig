{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'stats.analytics_builder.title'|trans }} – {{ parent() }}{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include('@Shared/_includes/subnav_stats.html.twig') }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs :items="[
            { label: 'link.statistics', path: path('app_stats_dashboard') },
            { label: 'stats.analytics_library.title', path: path('app_stats_analytics_library') },
            { label: 'stats.analytics_builder.title' }
        ]" />

        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle">{{ 'stats.analytics_builder.pretitle'|trans }}</div>
                    <h2 class="page-title" data-testid="stats-analytics-builder-title">{{ 'stats.analytics_builder.title'|trans }}</h2>
                    <p class="text-secondary mt-2 mb-0">{{ 'stats.analytics_builder.page_description'|trans }}</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    <div data-testid="stats-analytics-builder">
        {{ include('@Statistics/analytics_library/_builder_form.html.twig') }}
    </div>
{% endblock %}
