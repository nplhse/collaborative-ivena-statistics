{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'stats.analytics_library.title'|trans }} – {{ parent() }}{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include('@Shared/_includes/subnav_stats.html.twig') }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs :items="[
            { label: 'link.statistics', path: path('app_stats_dashboard') },
            { label: 'stats.analytics_library.title' }
        ]" />

        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle">{{ 'stats.analytics_library.pretitle'|trans }}</div>
                    <h2 class="page-title" data-testid="stats-analytics-library-title">
                        {{ 'stats.analytics_library.title'|trans }}
                    </h2>
                </div>
                <div class="col-auto">
                    <a href="{{ analyticsLibraryPage.builderUrl }}"
                       class="btn btn-outline-secondary d-inline-flex align-items-center gap-1"
                       data-testid="stats-analytics-builder-header-link">
                        <twig:ux:icon name="tabler:tool" style="height: 1.2em;" />
                        {{ 'stats.analytics_library.builder_short'|trans }}
                    </a>
                </div>
                {{ include('@Statistics/_header_controls.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    {% set page = analyticsLibraryPage %}

    <div data-testid="stats-analytics-library">
        <ul class="nav nav-tabs analytics-library-tabs mb-4" role="tablist">
            {% for tab in page.tabs %}
                <li class="nav-item" role="presentation">
                    <a class="nav-link{% if tab.active %} active{% endif %}"
                       href="{{ tab.url }}"
                       {% if tab.active %}aria-current="page"{% endif %}
                       data-testid="stats-analytics-library-tab-{{ tab.key }}">
                        {{ tab.label }}
                    </a>
                </li>
            {% endfor %}
        </ul>

        {% if page.activeTab == 'categories' %}
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                <div class="btn-group flex-wrap" role="group" aria-label="{{ 'stats.analytics_library.tab.categories'|trans }}">
                    {% for filter in page.categoryFilters %}
                        <a href="{{ filter.url }}"
                           class="btn{% if filter.active %} btn-primary{% endif %}"
                           {% if filter.active %}aria-current="true"{% endif %}
                           data-testid="stats-analytics-library-category-{{ filter.key == '' ? 'all' : filter.key }}">
                            {{ filter.label }}
                        </a>
                    {% endfor %}
                </div>
                <form method="get"
                      action="{{ path('app_stats_analytics_library') }}"
                      class="ms-auto"
                      data-controller="autosubmit"
                      data-testid="stats-analytics-library-search-form">
                    <input type="hidden" name="tab" value="categories">
                    {% if page.activeCategory %}
                        <input type="hidden" name="category" value="{{ page.activeCategory }}">
                    {% endif %}
                    {% for key, value in app.request.query.all %}
                        {% if key in ['scope', 'hospital', 'cohort', 'state', 'dispatch_area', 'period', 'year', 'month', 'quarter'] and value is not iterable %}
                            <input type="hidden" name="{{ key }}" value="{{ value }}">
                        {% endif %}
                    {% endfor %}
                    <div class="input-icon">
                        <input type="search"
                               name="q"
                               value="{{ page.searchQuery }}"
                               aria-label="{{ 'label.search'|trans }}"
                               placeholder="{{ 'stats.analytics_library.search_placeholder'|trans }}"
                               class="form-control w-9"
                               data-action="autosubmit#debouncedSubmit"
                               data-testid="stats-analytics-library-search">
                        <span class="input-icon-addon">
                            <twig:ux:icon name="tabler:search" style="height: 1.2em;" />
                        </span>
                    </div>
                </form>
            </div>
        {% endif %}

        {% set cards = page.activeTab == 'recommended' ? page.recommendedCards
            : (page.activeTab == 'favorites' ? page.favoriteCards
            : (page.activeTab == 'recent' ? page.recentCards
            : page.categoryCards)) %}

        {% if page.activeTab == 'recent' and page.frequentCards is not empty %}
            <h3 class="h4 mb-3">{{ 'stats.analytics_library.recent.last_used'|trans }}</h3>
        {% endif %}

        <div class="row row-cards mb-4">
            {% for card in cards %}
                <div class="col-12 col-md-6 col-xl-4">
                    {{ include('@Statistics/analytics_library/_view_card.html.twig', {card: card}) }}
                </div>
            {% else %}
                <div class="col-12">
                    <div class="empty">
                        <p class="empty-title">{{ 'stats.analytics_library.empty_title'|trans }}</p>
                        <p class="empty-subtitle text-secondary">{{ 'stats.analytics_library.empty_subtitle'|trans }}</p>
                    </div>
                </div>
            {% endfor %}
        </div>

        {% if page.activeTab == 'recent' and page.frequentCards is not empty %}
            <h3 class="h4 mb-3">{{ 'stats.analytics_library.recent.most_frequent'|trans }}</h3>
            <div class="row row-cards mb-4">
                {% for card in page.frequentCards %}
                    <div class="col-12 col-md-6 col-xl-4">
                        {{ include('@Statistics/analytics_library/_view_card.html.twig', {card: card}) }}
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {{ include('@Statistics/analytics_library/_builder_entry.html.twig', {builderUrl: page.builderUrl}) }}
    </div>
{% endblock %}
