<div class="border-top pt-4 mt-2" data-testid="stats-analytics-builder-entry">
    <p class="text-secondary text-uppercase small fw-semibold mb-2">{{ 'stats.analytics_library.advanced_section'|trans }}</p>
    <div class="card card-sm bg-light">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <h3 class="card-title mb-1">{{ 'stats.analytics_library.builder_entry_title'|trans }}</h3>
                <p class="text-secondary small mb-0">{{ 'stats.analytics_library.builder_entry_description'|trans }}</p>
            </div>
            <a href="{{ builderUrl }}" class="btn btn-outline-primary" data-testid="stats-analytics-builder-link">
                {{ 'stats.analytics_library.builder_entry_action'|trans }}
            </a>
        </div>
    </div>
</div>
