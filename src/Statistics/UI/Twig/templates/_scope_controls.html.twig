{% set vm = pageViewModel %}
{% set scopeTestIdPrefix = testIdPrefix|default('stats-scope') %}
{% set usePicker = pickerMode|default(false) %}

{% if vm.showScopeSecondaryPicker %}
    <div class="btn-group" role="group" aria-label="{{ 'stats.filter.scope_label'|trans({}, 'statistics') }}">
        <div class="btn-group" role="group">
            <button type="button"
                    class="btn dropdown-toggle"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    data-testid="{{ scopeTestIdPrefix }}-primary">
                {{ vm.scopePrimaryDropdownLabel }}
            </button>
            <div class="dropdown-menu">
                {% for item in vm.scopePrimaryMenu %}
                    <a class="dropdown-item{% if item.active %} active{% endif %}"
                       href="{{ item.url }}"
                       {% if usePicker %}data-action="benchmark-selection-picker#pickLink"{% endif %}>
                        {{ item.label }}
                    </a>
                {% endfor %}
            </div>
        </div>
        <div class="btn-group" role="group" data-controller="dropdown-typeahead">
            <button type="button"
                    class="btn dropdown-toggle"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    data-testid="{{ scopeTestIdPrefix }}-secondary">
                {{ vm.scopeSecondaryDropdownLabel|default('') }}
            </button>
            <div class="dropdown-menu dropdown-menu-end dropdown-menu-scrollable" data-dropdown-typeahead-target="menu">
                {% for row in vm.scopeSecondaryMenu %}
                    <a class="dropdown-item{% if row.active %} active{% endif %}"
                       href="{{ row.url }}"
                       {% if usePicker %}data-action="benchmark-selection-picker#pickLink"{% endif %}>
                        {{ row.label }}
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>
{% else %}
    <div class="btn-group">
        <button type="button"
                class="btn dropdown-toggle"
                data-bs-toggle="dropdown"
                aria-expanded="false"
                data-testid="{{ scopeTestIdPrefix }}{% if vm.showScopeSecondaryPicker %}-primary{% endif %}">
            {{ vm.scopePrimaryDropdownLabel }}
        </button>
        <div class="dropdown-menu dropdown-menu-end">
            {% for item in vm.scopePrimaryMenu %}
                <a class="dropdown-item{% if item.active %} active{% endif %}"
                   href="{{ item.url }}"
                   {% if usePicker %}data-action="benchmark-selection-picker#pickLink"{% endif %}>
                    {{ item.label }}
                </a>
            {% endfor %}
        </div>
    </div>
{% endif %}
