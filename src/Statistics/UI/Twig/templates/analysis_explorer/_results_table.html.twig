<div class="card"
     data-testid="stats-analysis-explorer-table"
     data-live-id="analysis-explorer-table-{{ analysisRevision }}">
    <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2 py-2">
        <div>
            <h3 class="card-title mb-0">{{ 'stats.generic_analysis.results_table_title'|trans }}</h3>
            {% if table %}
                <div class="text-secondary small mt-1" data-testid="stats-analysis-explorer-results-count">
                    {{ 'stats.generic_analysis.results_count'|trans({
                        count: table.total|number_format(0, ',', '.'),
                    }) }}
                </div>
            {% endif %}
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-striped mb-0"
                   data-testid="stats-analysis-explorer-table-body">
                <thead>
                    <tr>
                        <th>{{ table ? table.primaryDimensionLabel : '' }}</th>
                        {% if table and table.hasSeries %}
                            {% for seriesLabel in table.seriesLabels %}
                                <th class="text-end">{{ seriesLabel }}</th>
                            {% endfor %}
                            <th class="text-end">{{ 'stats.generic_analysis.table.footer_total'|trans }}</th>
                        {% else %}
                            <th class="text-end">{{ table ? table.metricLabel : '' }}</th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% if table %}
                        {% for row in table.rows %}
                            <tr>
                                <td>{{ row.bucketLabel }}</td>
                                {% if table.hasSeries %}
                                    {% for seriesLabel in table.seriesLabels %}
                                        <td class="text-end">{{ (row.seriesValues[seriesLabel] ?? 0)|number_format(0, ',', '.') }}</td>
                                    {% endfor %}
                                    <td class="text-end fw-semibold">{{ row.rowTotal|number_format(0, ',', '.') }}</td>
                                {% else %}
                                    <td class="text-end">{{ row.value|number_format(0, ',', '.') }}</td>
                                {% endif %}
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="{{ table.hasSeries ? (table.seriesLabels|length + 2) : 2 }}" class="text-muted p-3" data-testid="stats-analysis-explorer-table-empty">
                                    {{ 'stats.generic_analysis.no_data'|trans }}
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="2" class="text-muted p-3" data-testid="stats-analysis-explorer-table-empty">
                                {{ 'stats.generic_analysis.no_data'|trans }}
                            </td>
                        </tr>
                    {% endif %}
                </tbody>
                {% if table and table.hasData %}
                    <tfoot>
                        <tr class="fw-semibold border-top" data-testid="stats-analysis-explorer-table-footer">
                            <td>{{ 'stats.generic_analysis.table.footer_total'|trans }}</td>
                            {% if table.hasSeries %}
                                {% for seriesLabel in table.seriesLabels %}
                                    <td class="text-end">{{ (table.seriesTotals[seriesLabel] ?? 0)|number_format(0, ',', '.') }}</td>
                                {% endfor %}
                                <td class="text-end">{{ table.total|number_format(0, ',', '.') }}</td>
                            {% else %}
                                <td class="text-end">{{ table.total|number_format(0, ',', '.') }}</td>
                            {% endif %}
                        </tr>
                    {% endif %}
            </table>
        </div>
    </div>
</div>
