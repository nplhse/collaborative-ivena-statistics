<div class="card"
     data-testid="stats-analysis-explorer-table"
     data-live-id="analysis-explorer-table-{{ analysisRevision }}">
    <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2 py-2">
        <div>
            <h3 class="card-title mb-0">{{ 'stats.analysis_explorer.table.title'|trans }}</h3>
            {% if table and table.formattedTotals is not empty %}
                <div class="text-secondary small mt-1" data-testid="stats-analysis-explorer-results-count">
                    {% for column in table.metricColumns %}
                        {{ column.label }}: {{ table.formattedTotals[column.key] ?? '—' }}{% if not loop.last %} · {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-striped mb-0"
                   data-testid="stats-analysis-explorer-table-body">
                <thead>
                    <tr>
                        <th>{{ table ? table.primaryDimensionLabel : '' }}</th>
                        {% if table and table.hasSeries %}
                            {% for seriesLabel in table.seriesLabels %}
                                <th class="text-end">{{ seriesLabel }}</th>
                            {% endfor %}
                            <th class="text-end">{{ 'stats.analysis_explorer.table.footer_total'|trans }}</th>
                        {% elseif table %}
                            {% for column in table.metricColumns %}
                                <th class="text-end">{{ column.label }}</th>
                            {% endfor %}
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% if table %}
                        {% for row in table.rows %}
                            <tr>
                                <td>{{ row.bucketLabel }}</td>
                                {% if table.hasSeries %}
                                    {% for seriesLabel in table.seriesLabels %}
                                        <td class="text-end">{{ row.seriesValues[seriesLabel]|default(0)|number_format(1, ',', '.') }}</td>
                                    {% endfor %}
                                    <td class="text-end fw-semibold">{{ row.formattedRowTotal }}</td>
                                {% else %}
                                    {% for column in table.metricColumns %}
                                        <td class="text-end">{{ row.formattedMetricValues[column.key] ?? '—' }}</td>
                                    {% endfor %}
                                {% endif %}
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="{{ table.columnCount() }}" class="text-muted p-3" data-testid="stats-analysis-explorer-table-empty">
                                    {% if emptyReason %}
                                        {{ ('stats.analysis_explorer.empty_state.' ~ emptyReason)|trans }}
                                    {% else %}
                                        {{ 'stats.analysis_explorer.empty_state.no_data'|trans }}
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="2" class="text-muted p-3" data-testid="stats-analysis-explorer-table-empty">
                                {% if emptyReason %}
                                    {{ ('stats.analysis_explorer.empty_state.' ~ emptyReason)|trans }}
                                {% else %}
                                    {{ 'stats.analysis_explorer.empty_state.no_data'|trans }}
                                {% endif %}
                            </td>
                        </tr>
                    {% endif %}
                </tbody>
                {% if table and table.hasData %}
                    <tfoot>
                        <tr class="fw-semibold border-top" data-testid="stats-analysis-explorer-table-footer">
                            <td>{{ 'stats.analysis_explorer.table.footer_total'|trans }}</td>
                            {% if table.hasSeries %}
                                {% for seriesLabel in table.seriesLabels %}
                                    <td class="text-end">{{ table.formattedSeriesTotals[seriesLabel] ?? '—' }}</td>
                                {% endfor %}
                                <td class="text-end">{{ table.formattedGrandTotal }}</td>
                            {% else %}
                                {% for column in table.metricColumns %}
                                    <td class="text-end">{{ table.formattedTotals[column.key] ?? '—' }}</td>
                                {% endfor %}
                            {% endif %}
                        </tr>
                    </tfoot>
                {% endif %}
            </table>
        </div>
    </div>
</div>
