{% if dataQualityLazyLoad is defined and dataQualityLazyLoad %}
    <div class="offcanvas offcanvas-end data-quality-drawer"
         tabindex="-1"
         id="statsDataQualityDrawer"
         aria-labelledby="statsDataQualityDrawerLabel"
         data-testid="stats-data-quality-drawer"
         data-controller="data-quality-drawer"
         data-data-quality-drawer-url-value="{{ dataQualityDrawerUrl }}"
         data-action="show.bs.offcanvas->data-quality-drawer#load">
        <div class="offcanvas-header">
            <div>
                <h2 class="offcanvas-title mb-1" id="statsDataQualityDrawerLabel">
                    {{ 'stats.data_quality.drawer.title'|trans }}
                </h2>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ 'action.close'|trans }}"></button>
        </div>
        <div class="offcanvas-body d-flex align-items-center justify-content-center">
            <div class="spinner-border text-secondary" role="status" aria-hidden="true"></div>
        </div>
    </div>
{% elseif dataQualityReport is defined %}
    <div class="offcanvas offcanvas-end data-quality-drawer"
         tabindex="-1"
         id="statsDataQualityDrawer"
         aria-labelledby="statsDataQualityDrawerLabel"
         data-testid="stats-data-quality-drawer">
        {{ include('@Statistics/_data_quality_drawer_content.html.twig') }}
    </div>
{% endif %}
