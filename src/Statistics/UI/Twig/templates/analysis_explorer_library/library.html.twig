{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'stats.analysis_explorer.library.title'|trans }} – {{ parent() }}{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include('@Shared/_includes/subnav_stats.html.twig') }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <div class="d-flex align-items-start justify-content-between gap-3">
            <twig:Breadcrumbs :items="[
                { label: 'link.statistics', path: path('app_stats_dashboard') },
                { label: 'stats.analysis_explorer.library.title' }
            ]" />

            <div class="flex-shrink-0 d-print-none mt-2">
                {{ include('@Statistics/_data_quality_indicator.html.twig') }}
            </div>
        </div>

        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle">{{ 'stats.analysis_explorer.library.pretitle'|trans }}</div>
                    <h2 class="page-title" data-testid="stats-analysis-explorer-library-title">
                        {{ 'stats.analysis_explorer.library.title'|trans }}
                    </h2>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    {{ include('@Statistics/_data_quality_drawer.html.twig') }}

    <div data-testid="stats-analysis-explorer-library">
        {% for section in explorerLibraryPage.sections %}
            <section class="mb-5" data-testid="stats-analysis-explorer-library-section-{{ section.key }}">
                <h3 class="mb-3">{{ section.label }}</h3>

                {% if section.cards is defined %}
                    {% if section.cards is not empty %}
                        <div class="row g-4">
                            {% for card in section.cards %}
                                <div class="col-md-6 col-lg-4">
                                    {{ include('@Statistics/analysis_explorer_library/_view_card.html.twig', {card: card}) }}
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="alert alert-info" data-testid="stats-analysis-explorer-library-empty-{{ section.key }}">
                            {{ ('stats.analysis_explorer.library.empty.' ~ section.key)|trans }}
                        </div>
                    {% endif %}
                {% elseif section.categories is defined %}
                    {% for category in section.categories %}
                        <div class="mb-4" data-testid="stats-analysis-explorer-library-category-{{ category.key }}">
                            <h4 class="h5 mb-3">{{ category.label }}</h4>
                            <div class="row g-4">
                                {% for card in category.cards %}
                                    <div class="col-md-6 col-lg-4">
                                        {{ include('@Statistics/analysis_explorer_library/_view_card.html.twig', {
                                            card: card,
                                            categoryLabel: category.label,
                                        }) }}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% else %}
                        <div class="alert alert-info" data-testid="stats-analysis-explorer-library-empty-{{ section.key }}">
                            {{ ('stats.analysis_explorer.library.empty.' ~ section.key)|trans }}
                        </div>
                    {% endfor %}
                {% endif %}
            </section>
        {% endfor %}
    </div>
{% endblock %}
