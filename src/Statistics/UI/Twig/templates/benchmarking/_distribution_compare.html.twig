<div class="d-flex flex-column gap-3">
    {% for bucket in distribution.buckets %}
        {% set label = labelPrefix is defined ? (labelPrefix ~ bucket.key)|trans : bucket.label|trans %}
        {% set segmentClass = barClassMap is defined ? (barClassMap[bucket.key]|default(null)) : null %}
        <div>
            <div class="d-flex justify-content-between small mb-1">
                <span>{{ label }}</span>
                <span class="text-secondary">{{ bucket.primaryShare|number_format(1, ',', '.') }}% / {{ bucket.comparisonShare|number_format(1, ',', '.') }}%</span>
            </div>
            <div class="progress progress-sm">
                <div class="progress-bar {{ segmentClass ?? 'bg-primary' }}" style="width: {{ bucket.primaryShare }}%" title="{{ 'stats.benchmark.kpi.primary'|trans }}"></div>
            </div>
            <div class="progress progress-sm mt-1">
                <div class="progress-bar bg-secondary" style="width: {{ bucket.comparisonShare }}%" title="{{ 'stats.benchmark.kpi.comparison'|trans }}"></div>
            </div>
        </div>
    {% else %}
        <span class="text-secondary small">{{ 'stats.benchmark.summary.empty'|trans }}</span>
    {% endfor %}
</div>
