{% set periodVm = overviewPeriodViewModel %}
{% set periodTestIdPrefix = periodTestIdPrefix|default(testIdPrefix ~ '-period') %}

<div class="d-flex flex-column gap-2">
    <div class="fw-semibold">{{ columnTitleKey|trans }}</div>

    <div class="btn-list flex-wrap">
        {% if pageViewModel.showScopeSecondaryPicker %}
            <div class="btn-group" role="group" aria-label="{{ 'stats.filter.scope_label'|trans }}">
                <div class="btn-group" role="group">
                    <button type="button"
                            class="btn dropdown-toggle"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            data-testid="{{ testIdPrefix }}-scope-primary">
                        {{ pageViewModel.scopePrimaryDropdownLabel }}
                    </button>
                    <div class="dropdown-menu">
                        {% for item in pageViewModel.scopePrimaryMenu %}
                            <a class="dropdown-item{% if item.active %} active{% endif %}" href="{{ item.url }}">{{ item.label }}</a>
                        {% endfor %}
                    </div>
                </div>
                <div class="btn-group" role="group">
                    <button type="button"
                            class="btn dropdown-toggle"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            data-testid="{{ testIdPrefix }}-scope-secondary">
                        {{ pageViewModel.scopeSecondaryDropdownLabel|default('') }}
                    </button>
                    <div class="dropdown-menu dropdown-menu-end">
                        {% for row in pageViewModel.scopeSecondaryMenu %}
                            <a class="dropdown-item{% if row.active %} active{% endif %}" href="{{ row.url }}">{{ row.label }}</a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="btn-group">
                <button type="button"
                        class="btn dropdown-toggle"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        data-testid="{{ testIdPrefix }}-scope">
                    {{ pageViewModel.scopePrimaryDropdownLabel }}
                </button>
                <div class="dropdown-menu dropdown-menu-end">
                    {% for item in pageViewModel.scopePrimaryMenu %}
                        <a class="dropdown-item{% if item.active %} active{% endif %}" href="{{ item.url }}">{{ item.label }}</a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {{ include('@Statistics/dashboard/_overview_period_controls.html.twig') }}
    </div>

    <span class="badge {{ badgeClass }} align-self-start" data-testid="{{ testIdPrefix }}-cases">
        {{ 'stats.benchmark.cases'|trans({count: caseCount}) }}
    </span>
</div>
