{% set hasInsights = report.executiveSummary.above is not empty
    or report.executiveSummary.neutral is not empty
    or report.executiveSummary.below is not empty %}

{% if hasInsights %}
    <div class="card mb-3" data-testid="stats-benchmark-executive-summary">
        <div class="card-header py-2">
            <h3 class="card-title mb-0">{{ 'stats.benchmark.section.executive_summary'|trans }}</h3>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-secondary small mb-2">{{ 'stats.benchmark.summary.below'|trans }}</div>
                    <div class="d-flex flex-column gap-2">
                        {% for insight in report.executiveSummary.below %}
                            {{ include('@Statistics/benchmarking/_insight_item.html.twig', {insight: insight}) }}
                        {% else %}
                            <span class="text-secondary small">{{ 'stats.benchmark.summary.empty'|trans }}</span>
                        {% endfor %}
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-secondary small mb-2">{{ 'stats.benchmark.summary.neutral'|trans }}</div>
                    <div class="d-flex flex-column gap-2">
                        {% for insight in report.executiveSummary.neutral %}
                            {{ include('@Statistics/benchmarking/_insight_item.html.twig', {insight: insight}) }}
                        {% else %}
                            <span class="text-secondary small">{{ 'stats.benchmark.summary.empty'|trans }}</span>
                        {% endfor %}
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-secondary small mb-2">{{ 'stats.benchmark.summary.above'|trans }}</div>
                    <div class="d-flex flex-column gap-2">
                        {% for insight in report.executiveSummary.above %}
                            {{ include('@Statistics/benchmarking/_insight_item.html.twig', {insight: insight}) }}
                        {% else %}
                            <span class="text-secondary small">{{ 'stats.benchmark.summary.empty'|trans }}</span>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endif %}
