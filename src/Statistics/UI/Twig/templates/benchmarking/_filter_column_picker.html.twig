{% set periodVm = {
    primaryDropdownLabel: pickerSide.periodPrimaryDropdownLabel,
    secondaryDropdownLabel: pickerSide.periodSecondaryDropdownLabel,
    showSecondaryPicker: pickerSide.showPeriodSecondaryPicker,
    primaryMenu: pickerSide.periodPrimaryMenu,
    secondaryMenu: pickerSide.periodSecondaryMenu,
} %}
{% set periodTestIdPrefix = periodTestIdPrefix|default(testIdPrefix ~ '-period') %}
{% set pageViewModel = {
    showScopeSecondaryPicker: pickerSide.showScopeSecondaryPicker,
    scopePrimaryDropdownLabel: pickerSide.scopePrimaryDropdownLabel,
    scopeSecondaryDropdownLabel: pickerSide.scopeSecondaryDropdownLabel,
    scopePrimaryMenu: pickerSide.scopePrimaryMenu,
    scopeSecondaryMenu: pickerSide.scopeSecondaryMenu,
} %}

<div class="d-flex flex-column gap-2">
    <div class="fw-semibold">{{ columnTitleKey|trans }}</div>

    <div class="btn-list flex-wrap">
        {% if pickerSide.showScopeSecondaryPicker %}
            <div class="btn-group" role="group" aria-label="{{ 'stats.filter.scope_label'|trans }}">
                <div class="btn-group" role="group">
                    <button type="button"
                            class="btn dropdown-toggle"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            data-benchmark-selection-picker-target="{{ side }}ScopePrimaryLabel"
                            data-testid="{{ testIdPrefix }}-scope-primary">
                        {{ pickerSide.scopePrimaryDropdownLabel }}
                    </button>
                    <div class="dropdown-menu">
                        {% for item in pickerSide.scopePrimaryMenu %}
                            <button type="button"
                                    class="dropdown-item{% if item.active %} active{% endif %}"
                                    data-action="benchmark-selection-picker#select{{ side|capitalize }}ScopePrimary"
                                    data-benchmark-selection-picker-params-param="{{ item.params|json_encode|e('html_attr') }}"
                                    data-benchmark-selection-picker-label-param="{{ item.label|e('html_attr') }}">
                                {{ item.label }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
                <div class="btn-group" role="group" data-controller="dropdown-typeahead">
                    <button type="button"
                            class="btn dropdown-toggle"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            data-benchmark-selection-picker-target="{{ side }}ScopeSecondaryLabel"
                            data-testid="{{ testIdPrefix }}-scope-secondary">
                        {{ pickerSide.scopeSecondaryDropdownLabel|default('') }}
                    </button>
                    <div class="dropdown-menu dropdown-menu-end dropdown-menu-scrollable" data-dropdown-typeahead-target="menu">
                        {% for row in pickerSide.scopeSecondaryMenu %}
                            <button type="button"
                                    class="dropdown-item{% if row.active %} active{% endif %}"
                                    data-action="benchmark-selection-picker#select{{ side|capitalize }}ScopeSecondary"
                                    data-benchmark-selection-picker-params-param="{{ row.params|json_encode|e('html_attr') }}"
                                    data-benchmark-selection-picker-label-param="{{ row.label|e('html_attr') }}">
                                {{ row.label }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="btn-group">
                <button type="button"
                        class="btn dropdown-toggle"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        data-benchmark-selection-picker-target="{{ side }}ScopePrimaryLabel"
                        data-testid="{{ testIdPrefix }}-scope">
                    {{ pickerSide.scopePrimaryDropdownLabel }}
                </button>
                <div class="dropdown-menu dropdown-menu-end">
                    {% for item in pickerSide.scopePrimaryMenu %}
                        <button type="button"
                                class="dropdown-item{% if item.active %} active{% endif %}"
                                data-action="benchmark-selection-picker#select{{ side|capitalize }}ScopePrimary"
                                data-benchmark-selection-picker-params-param="{{ item.params|json_encode|e('html_attr') }}"
                                data-benchmark-selection-picker-label-param="{{ item.label|e('html_attr') }}">
                            {{ item.label }}
                        </button>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {{ include('@Statistics/benchmarking/_overview_period_picker_controls.html.twig', {
            overviewPeriodViewModel: periodVm,
        }) }}
    </div>
</div>
