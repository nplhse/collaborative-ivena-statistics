{% set periodVm = overviewPeriodViewModel %}
{% set periodTestIdPrefix = periodTestIdPrefix|default(testIdPrefix ~ '-period') %}

<div class="btn-group" role="group" aria-label="{{ 'stats.filter.period_label'|trans }}">
    {% if periodVm.showSecondaryPicker %}
        <div class="btn-group" role="group">
            <button type="button"
                    class="btn dropdown-toggle"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    data-benchmark-selection-picker-target="{{ side }}PeriodPrimaryLabel"
                    data-testid="{{ periodTestIdPrefix }}-primary">
                {{ periodVm.primaryDropdownLabel }}
            </button>
            <div class="dropdown-menu">
                {% for item in periodVm.primaryMenu %}
                    <button type="button"
                            class="dropdown-item{% if item.active %} active{% endif %}"
                            data-action="benchmark-selection-picker#select{{ side|capitalize }}PeriodPrimary"
                            data-benchmark-selection-picker-params-param="{{ item.params|json_encode|e('html_attr') }}"
                            data-benchmark-selection-picker-label-param="{{ item.label|e('html_attr') }}">
                        {{ item.label }}
                    </button>
                {% endfor %}
            </div>
        </div>
        <div class="btn-group" role="group" data-controller="dropdown-typeahead">
            <button type="button"
                    class="btn dropdown-toggle"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    data-benchmark-selection-picker-target="{{ side }}PeriodSecondaryLabel"
                    data-testid="{{ periodTestIdPrefix }}-secondary">
                {{ periodVm.secondaryDropdownLabel }}
            </button>
            <div class="dropdown-menu dropdown-menu-end dropdown-menu-scrollable" data-dropdown-typeahead-target="menu">
                {% for row in periodVm.secondaryMenu %}
                    {% if row.divider|default(false) %}
                        <div class="dropdown-divider"></div>
                    {% else %}
                        <button type="button"
                                class="dropdown-item{% if row.active %} active{% endif %}"
                                data-action="benchmark-selection-picker#select{{ side|capitalize }}PeriodSecondary"
                                data-benchmark-selection-picker-params-param="{{ row.params|json_encode|e('html_attr') }}"
                                data-benchmark-selection-picker-label-param="{{ row.label|e('html_attr') }}">
                            {{ row.label }}
                        </button>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    {% else %}
        <div class="btn-group">
            <button type="button"
                    class="btn dropdown-toggle"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    data-benchmark-selection-picker-target="{{ side }}PeriodPrimaryLabel"
                    data-testid="{{ periodTestIdPrefix }}-primary">
                {{ periodVm.primaryDropdownLabel }}
            </button>
            <div class="dropdown-menu dropdown-menu-end">
                {% for item in periodVm.primaryMenu %}
                    <button type="button"
                            class="dropdown-item{% if item.active %} active{% endif %}"
                            data-action="benchmark-selection-picker#select{{ side|capitalize }}PeriodPrimary"
                            data-benchmark-selection-picker-params-param="{{ item.params|json_encode|e('html_attr') }}"
                            data-benchmark-selection-picker-label-param="{{ item.label|e('html_attr') }}">
                        {{ item.label }}
                    </button>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>
