{% set pickerItems = [] %}
{% for item in comparePickerItems %}
    {% set pickerItems = pickerItems|merge([{type: item.type, id: item.id, label: item.label}]) %}
{% endfor %}

<div class="card mt-3" data-testid="stats-indication-compare-picker-card">
    <div class="card-body">
        <h3 class="card-title mb-2">{{ 'stats.indication.compare.picker_title'|trans({}, 'statistics') }}</h3>
        <p class="text-muted small mb-3">{{ 'stats.indication.compare.picker_help'|trans({}, 'statistics') }}</p>

        <div data-controller="indication-compare-picker"
             data-indication-compare-picker-items-value="{{ pickerItems|json_encode|e('html_attr') }}"
             data-indication-compare-picker-base-url-value="{{ compareBaseUrl|e('html_attr') }}">
            <div class="mb-3">
                <label class="form-label" for="stats-indication-compare-picker-a">
                    {{ 'stats.indication.compare.side_a'|trans({}, 'statistics') }}
                </label>
                <input type="text"
                       id="stats-indication-compare-picker-a"
                       class="form-control"
                       list="stats-indication-compare-picker-list-a"
                       placeholder="{{ 'stats.indication.picker.placeholder'|trans({}, 'statistics') }}"
                       autocomplete="off"
                       data-indication-compare-picker-target="inputA">
                <datalist id="stats-indication-compare-picker-list-a">
                    {% for item in comparePickerItems %}
                        <option value="{{ item.label }}"></option>
                    {% endfor %}
                </datalist>
            </div>
            <div class="mb-3">
                <label class="form-label" for="stats-indication-compare-picker-b">
                    {{ 'stats.indication.compare.side_b'|trans({}, 'statistics') }}
                </label>
                <input type="text"
                       id="stats-indication-compare-picker-b"
                       class="form-control"
                       list="stats-indication-compare-picker-list-b"
                       placeholder="{{ 'stats.indication.picker.placeholder'|trans({}, 'statistics') }}"
                       autocomplete="off"
                       data-indication-compare-picker-target="inputB">
                <datalist id="stats-indication-compare-picker-list-b">
                    {% for item in comparePickerItems %}
                        <option value="{{ item.label }}"></option>
                    {% endfor %}
                </datalist>
            </div>
            <button type="button"
                    class="btn btn-primary w-100"
                    data-action="indication-compare-picker#compare"
                    data-testid="stats-indication-compare-submit">
                {{ 'stats.indication.compare.submit'|trans({}, 'statistics') }}
            </button>
        </div>
    </div>
</div>
