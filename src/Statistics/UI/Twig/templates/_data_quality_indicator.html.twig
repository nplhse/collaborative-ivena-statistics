{% if dataQualityLazyLoad is defined and dataQualityLazyLoad %}
    <div data-controller="data-quality-indicator"
         data-data-quality-indicator-url-value="{{ dataQualityDrawerUrl }}">
        <button type="button"
                class="btn btn-sm d-inline-flex align-items-center gap-2 data-quality-indicator-btn"
                data-bs-toggle="offcanvas"
                data-bs-target="#statsDataQualityDrawer"
                aria-controls="statsDataQualityDrawer"
                data-testid="stats-data-quality-indicator">
            <span class="text-nowrap">
                {{ 'stats.data_quality.indicator.label'|trans({}, 'statistics') }}
                <span class="badge d-none"
                      data-data-quality-indicator-target="badge"
                      data-testid="stats-data-quality-indicator-badge"></span>
            </span>
        </button>
    </div>
{% elseif dataQualityReport is defined %}
    <button type="button"
            class="btn btn-sm d-inline-flex align-items-center gap-2 data-quality-indicator-btn"
            data-bs-toggle="offcanvas"
            data-bs-target="#statsDataQualityDrawer"
            aria-controls="statsDataQualityDrawer"
            data-testid="stats-data-quality-indicator">
        <span class="text-nowrap">
            {{ 'stats.data_quality.indicator.label'|trans({}, 'statistics') }}:
            <span class="badge {{ dataQualityReport.overallLevel.badgeClass }}">{{ dataQualityReport.overallLevel.labelKey|trans({}, 'statistics') }}</span>
        </span>
    </button>
{% endif %}
