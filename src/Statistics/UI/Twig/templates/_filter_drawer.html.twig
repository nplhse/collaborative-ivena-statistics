{% import '@Statistics/analysis_explorer/_edit_accordion_macros.html.twig' as editAccordion %}

{% set drawerValues = statsFilterDrawer.values|default(statsFilterDrawerValues|default({})) %}
{% set drawerChoices = statsFilterDrawer.choices|default({}) %}
{% set drawerFilterKeys = statsFilterDrawer.filterKeys|default([
    'gender', 'urgency', 'age_group', 'department', 'speciality',
    'requiresResus', 'requiresCathlab', 'isVentilated', 'isShock', 'isCPR',
    'isPregnant', 'isWorkAccident', 'isInfectious', 'infection',
]) %}
{% set allocationActive = drawerValues.urgency is not empty
    or drawerValues.department is not empty
    or drawerValues.speciality is not empty %}
{% set clinicalActive = drawerValues.requiresResus is not empty
    or drawerValues.requiresCathlab is not empty
    or drawerValues.isVentilated is not empty
    or drawerValues.isShock is not empty
    or drawerValues.isCPR is not empty
    or drawerValues.isPregnant is not empty
    or drawerValues.isWorkAccident is not empty
    or drawerValues.isInfectious is not empty
    or drawerValues.infection is not empty %}
{% set demographicsActive = drawerValues.gender is not empty
    or drawerValues.age_group is not empty %}

<div class="offcanvas offcanvas-end filter-drawer"
     tabindex="-1"
     id="statistics-filters-drawer"
     aria-labelledby="statistics-filters-drawer-label"
     data-testid="statistics-filters-drawer">
    <div class="offcanvas-header">
        <h2 class="offcanvas-title" id="statistics-filters-drawer-label">{{ 'label.filter.results'|trans({}, 'messages') }}</h2>
        <button type="button"
                class="btn-close"
                data-bs-dismiss="offcanvas"
                aria-label="{{ 'action.close'|trans({}, 'messages') }}"></button>
    </div>

    <div class="offcanvas-body">
        <form method="get"
              action="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|default({})) }}"
              id="statistics-filter-form">
            {% for key, value in app.request.query.all %}
                {% if key not in drawerFilterKeys and value is not iterable %}
                    <input type="hidden" name="{{ key }}" value="{{ value }}">
                {% endif %}
            {% endfor %}

            <div class="accordion accordion-flush" id="statistics-filter-drawer-accordion">
                <div class="accordion-item">
                    {{ editAccordion.header(
                        'statistics-filter-demographics-heading',
                        'statistics-filter-demographics-panel',
                        'stats.indication.section.demographics'|trans({}, 'statistics'),
                        'statistics-filter-section-demographics',
                        demographicsActive,
                    ) }}
                    {{ editAccordion.panel_start('statistics-filter-demographics-panel', 'statistics-filter-demographics-heading', demographicsActive) }}
                        <div class="accordion-body">
                            <div class="row g-2">
                                <div class="col-12">
                                    <label class="form-label" for="statistics-filter-gender">{{ 'label.gender'|trans({}, 'messages') }}</label>
                                    <select id="statistics-filter-gender" name="gender" class="form-select" data-testid="statistics-filter-gender">
                                        <option value="">{{ 'label.all'|trans({}, 'messages') }}</option>
                                        {% for value, label in drawerChoices.gender|default([]) %}
                                            <option value="{{ value }}" {{ drawerValues.gender == value ? 'selected' }}>{{ label }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="statistics-filter-age-group">{{ 'label.age_group'|trans({}, 'messages') }}</label>
                                    <select id="statistics-filter-age-group" name="age_group" class="form-select" data-testid="statistics-filter-age-group">
                                        <option value="">{{ 'label.all'|trans({}, 'messages') }}</option>
                                        {% for value, label in drawerChoices.age_group|default([]) %}
                                            <option value="{{ value }}" {{ drawerValues.age_group == value ? 'selected' }}>{{ label }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                        </div>
                    {{ editAccordion.panel_end() }}
                </div>

                <div class="accordion-item">
                    {{ editAccordion.header(
                        'statistics-filter-allocation-heading',
                        'statistics-filter-allocation-panel',
                        'label.allocation'|trans({}, 'messages'),
                        'statistics-filter-section-allocation',
                        allocationActive,
                    ) }}
                    {{ editAccordion.panel_start('statistics-filter-allocation-panel', 'statistics-filter-allocation-heading', allocationActive) }}
                        <div class="accordion-body">
                            <div class="row g-2">
                                <div class="col-12">
                                    <label class="form-label" for="statistics-filter-urgency">{{ 'label.urgency'|trans({}, 'messages') }}</label>
                                    <select id="statistics-filter-urgency" name="urgency" class="form-select" data-testid="statistics-filter-urgency">
                                        <option value="">{{ 'label.all_urgencies'|trans({}, 'messages') }}</option>
                                        {% for value, label in drawerChoices.urgency|default([]) %}
                                            <option value="{{ value }}" {{ drawerValues.urgency == value ? 'selected' }}>{{ label }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="statistics-filter-department">{{ 'label.department'|trans({}, 'messages') }}</label>
                                    <select id="statistics-filter-department" name="department" class="form-select" data-testid="statistics-filter-department">
                                        <option value="">{{ 'label.all_departments'|trans({}, 'messages') }}</option>
                                        {% for value, label in drawerChoices.department|default([]) %}
                                            <option value="{{ value }}" {{ drawerValues.department == value ? 'selected' }}>{{ label }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="statistics-filter-speciality">{{ 'label.speciality'|trans({}, 'messages') }}</label>
                                    <select id="statistics-filter-speciality" name="speciality" class="form-select" data-testid="statistics-filter-speciality">
                                        <option value="">{{ 'label.all_specialities'|trans({}, 'messages') }}</option>
                                        {% for value, label in drawerChoices.speciality|default([]) %}
                                            <option value="{{ value }}" {{ drawerValues.speciality == value ? 'selected' }}>{{ label }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                        </div>
                    {{ editAccordion.panel_end() }}
                </div>

                <div class="accordion-item">
                    {{ editAccordion.header(
                        'statistics-filter-clinical-heading',
                        'statistics-filter-clinical-panel',
                        'stats.analysis_explorer.dimension_group.clinical_care'|trans({}, 'statistics'),
                        'statistics-filter-section-clinical',
                        clinicalActive,
                    ) }}
                    {{ editAccordion.panel_start('statistics-filter-clinical-panel', 'statistics-filter-clinical-heading', clinicalActive) }}
                        <div class="accordion-body">
                            {{ include('@Shared/_includes/_clinical_care_filter_checkboxes.html.twig', {
                                values: drawerValues,
                                infectionChoices: drawerChoices.infection|default([]),
                                testIdPrefix: 'statistics-filter',
                                infectionSelectId: 'statistics-filter-infection',
                            }) }}
                        </div>
                    {{ editAccordion.panel_end() }}
                </div>
            </div>
        </form>
    </div>

    {% set activeFilterCount = statsFilterDrawer.activeCount|default(0) %}
    {{ include('@Statistics/_filter_drawer_footer.html.twig', {
        formId: 'statistics-filter-form',
        showReset: statsFilterDrawerResetUrl is defined and statsFilterDrawerResetUrl,
        resetUrl: statsFilterDrawerResetUrl|default(null),
        cancelTestId: 'statistics-filters-cancel',
        applyTestId: 'statistics-filters-apply',
        resetTestId: 'statistics-filters-reset',
    }) }}
</div>
