<div data-testid="{{ testIdPrefix }}-tiles">
    <div class="row row-deck row-cards g-3">
        {% for metric in metrics %}
            {% set deltaTone = metric.absoluteDelta > 0 ? 'success' : (metric.absoluteDelta < 0 ? 'danger' : 'primary') %}
            {% set deltaTextClass = deltaTone == 'danger' ? 'text-danger' : (deltaTone == 'success' ? 'text-success' : 'text-primary') %}
            {% set deltaBadgeClass = deltaTone == 'danger' ? 'bg-red-lt' : (deltaTone == 'success' ? 'bg-green-lt' : 'bg-primary-lt') %}
            {% set ratioTone = metric.ratio > 1 ? 'success' : (metric.ratio < 1 ? 'danger' : 'primary') %}
            {% set ratioBadgeClass = ratioTone == 'danger' ? 'bg-red-lt' : (ratioTone == 'success' ? 'bg-green-lt' : 'bg-primary-lt') %}
            {% set labelKey = metricLabelKeys[metric.key.value]|default('stats.benchmark.metric.' ~ metric.key.value) %}
            {% set tileColumnClass = columnClass|default('col-sm-6 col-lg-4') %}

            {% if metric.format.value == 'percent' %}
                {% set primaryLabel = metric.primaryValue|number_format(1, ',', '.') ~ '%' %}
                {% set comparisonLabel = metric.comparisonValue|number_format(1, ',', '.') ~ '%' %}
                {% set deltaLabel = (metric.absoluteDelta >= 0 ? '+' : '') ~ metric.absoluteDelta|number_format(1, ',', '.') ~ '%' %}
            {% elseif metric.format.value == 'count' %}
                {% set primaryLabel = metric.primaryValue|number_format(0, ',', '.') %}
                {% set comparisonLabel = metric.comparisonValue|number_format(0, ',', '.') %}
                {% set deltaLabel = (metric.absoluteDelta >= 0 ? '+' : '') ~ metric.absoluteDelta|number_format(0, ',', '.') %}
            {% elseif metric.format.value == 'minutes' %}
                {% set primaryLabel = metric.primaryValue|number_format(1, ',', '.') ~ ' min' %}
                {% set comparisonLabel = metric.comparisonValue|number_format(1, ',', '.') ~ ' min' %}
                {% set deltaLabel = (metric.absoluteDelta >= 0 ? '+' : '') ~ metric.absoluteDelta|number_format(1, ',', '.') ~ ' min' %}
            {% elseif metric.format.value == 'decimal' %}
                {% set primaryLabel = metric.primaryValue|number_format(1, ',', '.') %}
                {% set comparisonLabel = metric.comparisonValue|number_format(1, ',', '.') %}
                {% set deltaLabel = (metric.absoluteDelta >= 0 ? '+' : '') ~ metric.absoluteDelta|number_format(1, ',', '.') %}
            {% else %}
                {% set primaryLabel = metric.primaryValue|number_format(1, ',', '.') %}
                {% set comparisonLabel = metric.comparisonValue|number_format(1, ',', '.') %}
                {% set deltaLabel = (metric.absoluteDelta >= 0 ? '+' : '') ~ metric.absoluteDelta|number_format(1, ',', '.') %}
            {% endif %}

            <div class="{{ tileColumnClass }}">
                <div class="card h-100" data-testid="{{ testIdPrefix }}-{{ metric.key.value }}">
                    <div class="card-body d-flex flex-column">
                        <div class="subheader mb-2">
                            {{ labelKey|trans }}
                        </div>

                        {% if not suppressRatios %}
                            <div class="d-flex align-items-baseline gap-2 mb-3">
                                <div class="h2 mb-0 fw-bold {{ deltaTextClass }}">{{ deltaLabel }}</div>
                                <span class="badge {{ ratioBadgeClass }}">{{ metric.ratio|number_format(1, ',', '.') }}×</span>
                            </div>
                        {% else %}
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="h3 mb-0">{{ primaryLabel }}</div>
                                </div>
                                <div class="col-6 text-end">
                                    <div class="h3 mb-0 text-muted">{{ comparisonLabel }}</div>
                                </div>
                            </div>
                        {% endif %}

                        <div class="mt-auto d-flex justify-content-between small">
                            <span>
                                <span class="badge bg-primary-lt me-1">{{ sideAShortKey|trans }}</span>
                                <span class="text-muted">{{ primaryLabel }}</span>
                            </span>
                            <span class="text-end">
                                <span class="badge bg-secondary-lt me-1">{{ sideBShortKey|trans }}</span>
                                <span class="text-muted">{{ comparisonLabel }}</span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
