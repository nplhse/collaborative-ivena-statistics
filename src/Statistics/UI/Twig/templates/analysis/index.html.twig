{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}Analysis: {{ statisticsHeadingScope }} · {{ statisticsHeadingPeriod }} – {{ parent() }}{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include(('@Shared/_includes/subnav_stats.html.twig')) }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs :items="[
            { label: 'link.statistics', path: path('app_stats_dashboard') },
            { label: 'link.stats.analysis' }
        ]" />

        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle" data-testid="stats-heading-scope">
                        {{ statisticsHeadingScope }}
                    </div>
                    <h2 class="page-title" data-testid="stats-heading-period">
                        {{ statisticsHeadingPeriod }}
                    </h2>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    <div class="row g-4 align-items-start">
        <aside class="col-12 col-lg-3 col-xl-2">
            <div class="position-lg-sticky" style="top: 1rem;">
                {{ include('@Statistics/dashboard/_statistics_filter_bar.html.twig') }}
            </div>
        </aside>
        <div class="col-12 col-lg-9 col-xl-10 min-w-0">
            <div class="card mb-3">
                <div class="card-body py-3">
                    <div class="row g-3 align-items-end flex-wrap">
                        {{ include('@Statistics/_definition_select_control.html.twig', {
                            triggerId: 'stats-analysis-select-trigger',
                            labelKey: 'stats.analysis.select_label',
                            definitions: analysisPage.analysisDefinitions,
                            currentKey: analysisPage.currentAnalysisKey,
                            selectUrls: analysisPage.analysisSelectUrls,
                        }) }}
                        <div class="col-12 col-sm-auto">
                            <span class="form-label d-block mb-1">{{ 'stats.analysis.presentation_label'|trans }}</span>
                            {{ include('@Statistics/analysis/_view_toggle.html.twig', {toolbar: analysisPage.toolbar}) }}
                        </div>
                        {% if analysisPage.toolbar.showDimensionSelector %}
                            <div class="col-12">
                                {{ include('@Statistics/analysis/_dimension_selector.html.twig', {toolbar: analysisPage.toolbar}) }}
                            </div>
                        {% endif %}
                        {% if analysisPage.toolbar.showChartMeasureSelector %}
                            <div class="col-12">
                                {{ include('@Statistics/analysis/_chart_measure_selector.html.twig', {toolbar: analysisPage.toolbar}) }}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div data-testid="stats-analysis-widget">
                {{ include('@Statistics/dashboard/_widget_renderer.html.twig', {
                    widget: analysisPage.analysisWidget,
                    analysisChartStyle: {
                        chartBarUrl: analysisPage.toolbar.chartBarUrl,
                        chartLineUrl: analysisPage.toolbar.chartLineUrl,
                        currentChartType: analysisPage.toolbar.currentChartType,
                    },
                }) }}
            </div>
        </div>
    </div>
{% endblock %}
