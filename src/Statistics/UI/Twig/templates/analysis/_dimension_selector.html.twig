<span class="form-label d-block mb-1">{{ 'stats.analysis.dimension_label'|trans }}</span>
<div class="btn-group flex-wrap"
     role="group"
     aria-label="{{ 'stats.analysis.dimension_label'|trans }}"
     data-testid="stats-analysis-dimension-selector">
    <a href="{{ toolbar.dimensionTotalUrl }}"
       class="btn{% if toolbar.currentAnalysisDimension == 'total' %} active{% endif %}"
       data-testid="stats-analysis-dimension-total">
        {{ 'stats.analysis.dimension.total'|trans }}
    </a>
    <a href="{{ toolbar.dimensionGenderUrl }}"
       class="btn{% if toolbar.currentAnalysisDimension == 'gender' %} active{% endif %}"
       data-testid="stats-analysis-dimension-gender">
        {{ 'stats.analysis.dimension.gender'|trans }}
    </a>
    <a href="{{ toolbar.dimensionUrgencyUrl }}"
       class="btn{% if toolbar.currentAnalysisDimension == 'urgency' %} active{% endif %}"
       data-testid="stats-analysis-dimension-urgency">
        {{ 'stats.analysis.dimension.urgency'|trans }}
    </a>
    <a href="{{ toolbar.dimensionResourcesUrl }}"
       class="btn{% if toolbar.currentAnalysisDimension == 'resources' %} active{% endif %}"
       data-testid="stats-analysis-dimension-resources">
        {{ 'stats.analysis.dimension.resources'|trans }}
    </a>
    <a href="{{ toolbar.dimensionFeaturesUrl }}"
       class="btn{% if toolbar.currentAnalysisDimension == 'features' %} active{% endif %}"
       data-testid="stats-analysis-dimension-features">
        {{ 'stats.analysis.dimension.features'|trans }}
    </a>
</div>
