<div class="card mb-0" data-testid="stats-explorer-sidebar">
    <div class="card-body">
        {% for section in statsExplorerSections %}
            {% if section.entries is not empty %}
                <div class="subheader mb-2">{{ section.labelKey|trans }}</div>
                <div class="list-group list-group-transparent mb-4">
                    {% for entry in section.entries %}
                        <a href="{{ entry.url }}"
                           class="list-group-item list-group-item-action d-flex align-items-center{% if entry.active %} active{% endif %}">
                            {{ entry.labelKey|trans }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        {% endfor %}
    </div>
</div>
