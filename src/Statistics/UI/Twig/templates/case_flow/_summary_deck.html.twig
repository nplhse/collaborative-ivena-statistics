<div class="row row-deck row-cards g-3 mb-0" data-testid="stats-case-flow-kpis">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="subheader">{{ 'stats.case_flow.kpi.total_cases'|trans }}</div>
                <div class="h1 mt-2 mb-0">{{ dashboard.kpis.totalCases|number_format(0, ',', '.') }}</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="subheader">{{ 'stats.case_flow.kpi.regional_share'|trans }}</div>
                <div class="h1 mt-2 mb-0">
                    {% if dashboard.kpis.regionalSharePercent is not null %}
                        {{ dashboard.kpis.regionalSharePercent }}%
                    {% else %}
                        —
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="subheader">{{ 'stats.case_flow.kpi.mean_transport'|trans }}</div>
                <div class="h1 mt-2 mb-0">
                    {% if dashboard.kpis.meanTransportMinutes is not null %}
                        {{ dashboard.kpis.meanTransportMinutes|round(0) }} {{ 'stats.case_flow.kpi.minutes'|trans }}
                    {% else %}
                        —
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
