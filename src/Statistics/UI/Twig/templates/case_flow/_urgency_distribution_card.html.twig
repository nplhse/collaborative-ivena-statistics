{# Hospital-origin mode: urgency distribution in overview bar style #}
<div class="card" data-testid="stats-case-flow-urgency-structure">
    <div class="card-body">
        <p class="mb-2">{{ 'stats.case_flow.section.urgency'|trans({}, 'statistics') }}</p>
        {% if dashboard.urgencyDistribution is not empty %}
            <div class="progress progress-separated mb-3">
                {% for slice in dashboard.urgencyDistribution %}
                    {% set barClass = slice.key == 'emergency' ? 'bg-red' : (slice.key == 'inpatient' ? 'bg-yellow' : (slice.key == 'outpatient' ? 'bg-green' : 'bg-secondary')) %}
                    <div class="progress-bar {{ barClass }}"
                         style="width: {{ slice.percent }}%"
                         aria-label="{{ slice.labelTranslationKey|trans({}, 'statistics') }}"></div>
                {% endfor %}
            </div>
            <div class="row">
                {% for slice in dashboard.urgencyDistribution %}
                    {% set barClass = slice.key == 'emergency' ? 'bg-red' : (slice.key == 'inpatient' ? 'bg-yellow' : (slice.key == 'outpatient' ? 'bg-green' : 'bg-secondary')) %}
                    <div class="col-auto d-flex align-items-center {% if not loop.first %}px-2{% else %}pe-2{% endif %}">
                        <span class="legend me-2 {{ barClass }}"></span>
                        <span>{{ slice.labelTranslationKey|trans({}, 'statistics') }}</span>
                        <span class="text-muted ms-2">{{ slice.count|number_format(0, ',', '.') }} ({{ slice.percent }}%)</span>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-muted small mb-0">{{ 'stats.case_flow.structure.empty'|trans({}, 'statistics') }}</p>
        {% endif %}
    </div>
</div>
