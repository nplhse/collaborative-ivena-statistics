{# @var card \App\Statistics\CaseFlow\Application\DTO\CaseFlowStructureDistributionCard #}
<div class="card" data-testid="{{ testId|default('stats-case-flow-structure-card') }}">
    <div class="card-body">
        <p class="mb-2">{{ card.titleTranslationKey|trans({}, 'statistics') }}</p>
        {% if card.segments is not empty %}
            <div class="progress progress-separated mb-3">
                {% for segment in card.segments %}
                    <div class="progress-bar {{ segment.barClass }}"
                         style="width: {{ segment.percent }}%"
                         aria-label="{{ segment.labelTranslationKey|trans({}, 'statistics') }}"></div>
                {% endfor %}
            </div>
            <div class="row">
                {% for segment in card.segments %}
                    <div class="col-auto d-flex align-items-center {% if not loop.first %}px-2{% else %}pe-2{% endif %}">
                        <span class="legend me-2 {{ segment.barClass }}"></span>
                        <span>{{ segment.labelTranslationKey|trans({}, 'statistics') }}</span>
                        <span class="text-muted ms-2">{{ segment.count|number_format(0, ',', '.') }} ({{ segment.percent }}%)</span>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-muted small mb-0">{{ 'stats.case_flow.structure.empty'|trans({}, 'statistics') }}</p>
        {% endif %}
    </div>
</div>
