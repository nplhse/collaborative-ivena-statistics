{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}Reports: {{ statisticsHeadingScope }} · {{ statisticsHeadingPeriod }} – {{ parent() }}{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include(('@Shared/_includes/subnav_stats.html.twig')) }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs :items="[
            { label: 'link.statistics', path: path('app_stats_dashboard') },
            { label: 'link.stats.reports' }
        ]" />

        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle" data-testid="stats-heading-scope">
                        {{ statisticsHeadingScope }}
                    </div>
                    <h2 class="page-title" data-testid="stats-heading-period">
                        {{ statisticsHeadingPeriod }}
                    </h2>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    <div class="row g-4 align-items-start">
        <aside class="col-12 col-lg-3 col-xl-2">
            <div class="position-lg-sticky" style="top: 1rem;">
                {{ include('@Statistics/dashboard/_statistics_filter_bar.html.twig') }}
            </div>
        </aside>
        <div class="col-12 col-lg-9 col-xl-10 min-w-0">
            <div class="card mb-3">
                <div class="card-body py-3">
                    <div class="row g-3 align-items-end flex-wrap">
                        {% set selectedReportDescription = null %}
                        {% for def in reportsPage.reportDefinitions %}
                            {% if def.key == reportsPage.currentReportKey %}
                                {% set selectedReportDescription = def.descriptionTranslationKey %}
                            {% endif %}
                        {% endfor %}
                        {{ include('@Statistics/_definition_select_control.html.twig', {
                            triggerId: 'stats-reports-select-trigger',
                            labelKey: 'stats.reports.select_label',
                            definitions: reportsPage.reportDefinitions,
                            currentKey: reportsPage.currentReportKey,
                            selectUrls: reportsPage.reportSelectUrls,
                            selectedDescriptionKey: selectedReportDescription,
                        }) }}
                    </div>
                </div>
            </div>

            <div data-testid="stats-reports-widget">
                {{ include('@Statistics/dashboard/_widget_renderer.html.twig', {widget: reportsPage.reportWidget}) }}
            </div>
        </div>
    </div>
{% endblock %}
