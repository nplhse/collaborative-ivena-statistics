{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'stats.reports.page_title'|trans }} · {{ statisticsHeadingScope }} · {{ statisticsHeadingPeriod }} – {{ parent() }}{% endblock %}

{% block header %}
    {% embed '@Shared/_embeds/header.html.twig' %}
        {% block header_after %}
            {{ include(('@Shared/_includes/subnav_stats.html.twig')) }}
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs :items="[
            { label: 'link.statistics', path: path('app_stats_dashboard') },
            { label: 'link.stats.reports' }
        ]" />

        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle" data-testid="stats-heading-scope">
                        {{ statisticsHeadingScope }}
                    </div>
                    <h2 class="page-title" data-testid="stats-heading-period">
                        {{ statisticsHeadingPeriod }}
                    </h2>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    <div class="row g-4 align-items-start">
        <aside class="col-12 col-lg-3 col-xl-2">
            <div class="position-lg-sticky" style="top: 1rem;">
                {{ include('@Statistics/dashboard/_statistics_filter_bar.html.twig') }}
            </div>
        </aside>
        <div class="col-12 col-lg-9 col-xl-10 min-w-0">
            <div class="card mb-3">
                <div class="card-body py-3">
                    <div class="row g-3 align-items-end flex-wrap">
                        <div class="col min-w-0">
                            <label class="form-label mb-1" for="stats-reports-select-trigger">{{ 'stats.reports.select_label'|trans }}</label>
                            <div class="dropdown w-100">
                                <button id="stats-reports-select-trigger"
                                        class="btn btn-primary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
                                        type="button" data-bs-toggle="dropdown" data-testid="stats-reports-select">
                                    {% for def in reportDefinitions %}
                                        {% if def.key == currentReportKey %}
                                            {{ def.labelTranslationKey|trans }}
                                        {% endif %}
                                    {% endfor %}
                                </button>
                                <div class="dropdown-menu w-100">
                                    {% for def in reportDefinitions %}
                                        <a class="dropdown-item{% if def.key == currentReportKey %} active{% endif %}"
                                           href="{{ reportSelectUrls[def.key] }}">
                                            {{ def.labelTranslationKey|trans }}
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                            {% for def in reportDefinitions %}
                                {% if def.key == currentReportKey %}
                                    <p class="text-secondary small mt-2 mb-0" data-testid="stats-reports-description">
                                        {{ def.descriptionTranslationKey|trans }}
                                    </p>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            <div data-testid="stats-reports-widget">
                {{ include('@Statistics/dashboard/_statistic_widget.html.twig', {widget: reportWidget}) }}
            </div>
        </div>
    </div>
{% endblock %}
