{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'title.register'|trans({}, 'user') }} - {{ parent() }}{% endblock %}

{% block page_body %}
    <div class="container container-tight py-4">
        <twig:Card size="md">
            <h2 class="text-center mb-4">{{ 'title.register'|trans({}, 'user') }}</h2>
            {{ form_start(registrationForm) }}
                {{ form_row(registrationForm.username) }}
                {{ form_row(registrationForm.email) }}
                {{ form_row(registrationForm.plainPassword) }}
                {% set termsPageUrl = page_url_by_key('terms') %}
                {% set acceptTerms = registrationForm.acceptTerms %}
                <div class="mb-3">
                    <label class="d-flex align-items-center gap-2 mb-0" for="{{ acceptTerms.vars.id }}">
                        <input
                            type="checkbox"
                            id="{{ acceptTerms.vars.id }}"
                            name="{{ acceptTerms.vars.full_name }}"
                            class="form-check-input m-0 flex-shrink-0{{ acceptTerms.vars.valid ? '' : ' is-invalid' }}"
                            value="1"
                            {% if acceptTerms.vars.checked %}checked="checked"{% endif %}
                            {% if acceptTerms.vars.required %}required="required"{% endif %}
                        />
                        <span class="form-check-label required mb-0">
                            {{- 'label.registration.accept_terms_prefix'|trans({}, 'messages') -}}
                            {%- if termsPageUrl -%}
                                <a href="{{ termsPageUrl }}" class="link-primary">{{ 'link.terms'|trans({}, 'shared') }}</a>
                            {%- else -%}
                                {{- 'link.terms'|trans({}, 'shared') -}}
                            {%- endif -%}
                        </span>
                    </label>
                    {{ form_errors(acceptTerms) }}
                </div>
                {% do acceptTerms.setRendered %}
                <div class="form-footer">
                    <button class="btn btn-primary w-100" type="submit">{{ 'label.register'|trans({}, 'messages') }}</button>
                </div>
            {{ form_end(registrationForm) }}
            <div class="text-center text-secondary mt-3">
                {{ 'label.already_have_account'|trans({}, 'messages') }}
                <a href="{{ path('app_login') }}">{{ 'label.login'|trans({}, 'messages') }}</a>
            </div>
        </twig:Card>
    </div>
{% endblock %}
