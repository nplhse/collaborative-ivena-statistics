{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'title.login'|trans({}, 'messages') }} - {{ parent() }}{% endblock %}

{% block page_body %}
    <div class="container container-tight py-4">
        <twig:Card
            size="md"
        >
            <h2 class="text-center mb-4">{{ 'title.login'|trans({}, 'messages') }}</h2>

            <form method="post">
                {% set consentRequiredKey = 'flash.security.cookie_consent_required' %}
                {% set isConsentError = error and error.messageKey == consentRequiredKey %}
                {% if isConsentError or (not hasConsentDecision and showConsentHint) %}
                    <div class="alert {{ isConsentError ? 'alert-danger' : 'alert-warning' }}" role="alert">
                        {{ consentRequiredKey|trans({}, 'security') }}
                        <a class="alert-link" href="{{ path('app_cookie_preferences') }}">{{ 'cookie.banner.settings'|trans({}, 'shared') }}</a>
                    </div>
                {% elseif error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                {{ form_row(form.username) }}

                {{ form_row(form.password) }}

                {{ form_row(form._remember_me) }}

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}" />

                <div class="form-footer">
                    <button type="submit" class="btn btn-primary w-100">{{ 'label.signin'|trans({}, 'messages') }}</button>
                </div>
            </form>
            <div class="text-center text-secondary mt-3">
                <a href="{{ path('app_forgot_password_request') }}">{{ 'label.forgot_password'|trans({}, 'user') }}</a>
                &middot;
                <a href="{{ path('app_register') }}">{{ 'label.register'|trans({}, 'messages') }}</a>
            </div>
        </twig:Card>
    </div>
{% endblock %}
