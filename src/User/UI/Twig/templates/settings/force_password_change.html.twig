{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'title.set_new_password'|trans }} - {{ parent() }}{% endblock %}

{% block page_body %}
    <div class="container container-tight py-4">
        <twig:Card size="md">
            <h2 class="text-center mb-3">{{ 'title.set_new_password'|trans }}</h2>
            <p class="text-secondary text-center mb-4">Your credentials have expired. Please choose a new password to continue.</p>
            {{ form_start(passwordForm) }}
                {{ form_row(passwordForm.plainPassword.first) }}
                {{ form_row(passwordForm.plainPassword.second) }}
                <div class="form-footer">
                    <button class="btn btn-primary w-100">{{ 'label.save_new_password'|trans }}</button>
                </div>
            {{ form_end(passwordForm) }}
        </twig:Card>
    </div>
{% endblock %}
