{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'title.settings'|trans }} - {{ parent() }}{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs
            :items="[
                { label: 'title.settings' },
            ]"
        />
        <div class="page-header d-print-none">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <h2 class="page-title">{{ 'title.settings.account'|trans }}</h2>
                    <div class="text-secondary mt-1">{{ 'text.settings.account_intro'|trans }}</div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_body %}
    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-12">
                    <div class="card">
                        <div class="row g-0">
                            <div class="col-12 col-md-3 border-end">
                                <div class="card-body">
                                    <h4 class="subheader">{{ 'label.settings.my_account'|trans }}</h4>
                                    <div class="list-group list-group-transparent">
                                        <a class="list-group-item list-group-item-action d-flex align-items-center active" href="{{ path('app_settings_index') }}">
                                            {{ 'label.settings.my_account'|trans }}
                                        </a>
                                        <a class="list-group-item list-group-item-action d-flex align-items-center" href="{{ path('app_settings_email') }}">
                                            {{ 'label.settings.change_email'|trans }}
                                        </a>
                                        <a class="list-group-item list-group-item-action d-flex align-items-center" href="{{ path('app_settings_password') }}">
                                            {{ 'label.settings.set_new_password'|trans }}
                                        </a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-md-9">
                                <div class="card-header">
                                    <h3 class="card-title">{{ 'label.settings.my_account'|trans }}</h3>
                                </div>
                                <div class="card-body">
                                    <h4 class="subheader mb-3">{{ 'label.settings.profile_details'|trans }}</h4>
                                    <div class="row g-3 mb-4">
                                        <div class="col-md-6">
                                            <label class="form-label">{{ 'label.username'|trans }}</label>
                                            <input class="form-control" value="{{ app.user.userIdentifier }}" readonly />
                                            <small class="form-hint">{{ 'help.settings.username_fixed'|trans }}</small>
                                        </div>
                                    </div>

                                    <h4 class="subheader mb-3">{{ 'label.email'|trans }}</h4>
                                    <div class="row g-3 align-items-end mb-2">
                                        <div class="col-md-8">
                                            <label class="form-label">{{ 'label.email_address'|trans }}</label>
                                            <input class="form-control" value="{{ app.user.email }}" readonly />
                                        </div>
                                        <div class="col-md-4 d-grid">
                                            <a class="btn" href="{{ path('app_settings_email') }}">{{ 'label.settings.change_email'|trans }}</a>
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <small class="form-hint d-flex align-items-center gap-2">
                                            <span>{{ 'label.settings.verification_status'|trans }}</span>
                                            <span class="badge {{ app.user.isVerified ? 'bg-green text-green-fg' : 'bg-yellow text-yellow-fg' }}">
                                                {{ app.user.isVerified ? 'label.verified'|trans : 'label.not_verified'|trans }}
                                            </span>
                                        </small>
                                        {% if not app.user.isVerified %}
                                            <form method="post" action="{{ path('app_settings_resend_verification') }}" class="mt-2">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('resend_verification_email') }}">
                                                <button class="btn btn-outline-secondary" type="submit">{{ 'label.settings.resend_verification'|trans }}</button>
                                            </form>
                                        {% endif %}
                                    </div>

                                    <h4 class="subheader mb-3">{{ 'label.password'|trans }}</h4>
                                    <div class="row g-3 align-items-end">
                                        <div class="col-md-4 d-grid">
                                            <a class="btn" href="{{ path('app_settings_password') }}">{{ 'label.settings.set_new_password'|trans }}</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
