{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ 'title.import.index'|trans({}, 'import') }} - {{ parent() }}{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs :items="[
            { label: 'link.import' }
        ]" />

        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    {% block page_intro %}
                        <h2 class="page-title">
                            {% block page_title %}{{ 'title.import.index'|trans({}, 'import') }}{% endblock %}
                        </h2>
                    {% endblock %}
                    {% block page_subtitle %}
                        {% block result_count %}
                            <div id="result-count" class="text-body-secondary mt-1">
                                {{ 'label.pagination_numbers'|trans(({first: paginator.firstResultNumber, last: paginator.lastResultNumber, total: paginator.numResults}), 'messages') }}
                            </div>
                        {% endblock %}
                    {% endblock %}
                </div>
                <div class="col-auto ms-auto d-print-none">
                    <div class="btn-list">
                        <a class="btn btn-primary" href="{{ path('app_import_new') }}">{{ 'label.import.new'|trans({}, 'import') }}</a>
                        <div class="btn-group">
                            <button
                                class="btn"
                                type="button"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#import-filters"
                                aria-controls="import-filters"
                            >
                                {% if activeFilterCount < 1 %}
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="icon"
                                        width="24" height="24" viewBox="0 0 24 24"
                                        stroke-width="2" stroke="currentColor"
                                        fill="none"
                                        stroke-linecap="round" stroke-linejoin="round"
                                    >
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                        <path d="M4 4h16l-6 8v6l-4 -2v-4z" />
                                    </svg>
                                {% else %}
                                    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                        <path fill="currentColor" d="M20 3H4a1 1 0 0 0-1 1v2.227l.008.223a3 3 0 0 0 .772 1.795L8 12.886V21a1 1 0 0 0 1.316.949l6-2l.108-.043A1 1 0 0 0 16 19v-6.586l4.121-4.12A3 3 0 0 0 21 6.171V4a1 1 0 0 0-1-1"/>
                                    </svg>
                                {% endif %}
                                <span class="ms-2">{{ 'label.filters'|trans({}, 'messages') }}</span>
                                {% if activeFilterCount > 0 %}
                                    <span class="badge text-primary ms-2">{{ activeFilterCount }}</span>
                                {% endif %}
                            </button>
                            {% if activeFilterCount > 0 %}
                                <a
                                    href="{{ path('app_import_index', {search: search, sortBy: sortBy, orderBy: orderBy}) }}"
                                    class="btn btn-icon btn-outline"
                                    title="{{ 'label.filters.reset'|trans({}, 'messages') }}"
                                    aria-label="{{ 'label.filters.reset'|trans({}, 'messages') }}"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="icon"
                                        width="24" height="24" viewBox="0 0 24 24"
                                        stroke-width="2" stroke="currentColor"
                                        fill="none"
                                        stroke-linecap="round" stroke-linejoin="round"
                                    >
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                        <path d="M18 6l-12 12" />
                                        <path d="M6 6l12 12" />
                                    </svg>
                                </a>
                            {% endif %}
                        </div>

                        <form
                            method="GET"
                            action="{{ path('app_import_index') }}"
                            data-controller="autosubmit"
                            data-turbo-frame="import-list"
                        >
                            {% for key, value in app.request.query.all %}
                                {% if key != 'search' and value is not iterable %}
                                    <input type="hidden" name="{{ key }}" value="{{ value }}">
                                {% endif %}
                            {% endfor %}
                            <div class="input-icon">
                                <input
                                    type="search"
                                    name="search"
                                    value="{{ app.request.query.get('search') }}"
                                    aria-label="{{ 'label.search'|trans({}, 'messages') }}"
                                    placeholder="{{ 'label.search'|trans({}, 'messages') }}"
                                    class="form-control d-inline-block w-9 me-3"
                                    data-action="autosubmit#debouncedSubmit"
                                    autofocus
                                >
                                <span class="input-icon-addon">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="icon"
                                        width="24" height="24" viewBox="0 0 24 24"
                                        stroke-width="2" stroke="currentColor"
                                        fill="none"
                                        stroke-linecap="round" stroke-linejoin="round"
                                    >
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                        <circle cx="10" cy="10" r="7" />
                                        <line x1="21" y1="21" x2="15" y2="15" />
                                    </svg>
                                </span>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_content %}
    <turbo-frame id="import-list" data-turbo-action="advance">
        {% import '@Shared/_macros/filters.html.twig' as activeFilters %}

        {% if activeFilterCount > 0 %}
            <div class="alert alert-info" role="alert">
                <strong class="text-info">{{ 'label.filters.active'|trans({}, 'messages') }}:</strong>
                {{ activeFilters.import_filter_badges(filters, hospitals, owners) }}
            </div>
        {% endif %}

        {% if search is not empty %}
            <twig:Alert type="info" :message="'label.search_for'|trans(({term: search}), 'messages')" />
        {% endif %}

        <twig:DataTable
            :paginator="paginator"
            :paginationRoute="pagination_route"
        >
            {% import '@Shared/_macros/pagination.html.twig' as pagination %}

            <table class="table data-table-card">
                <thead>
                <tr>
                    <th class="col-1">
                        <a class="text-muted" href="{{ path('app_import_index', {
                            ... app.request.query.all(),
                            sortBy: 'type',
                            orderBy: sortBy == 'type' and orderBy == 'asc' ? 'desc' : 'asc',
                        }) }}">
                            {{ 'label.type'|trans({}, 'messages') }} {{ pagination.sortArrow('type', sortBy, orderBy) }}
                        </a>
                    </th>
                    <th class="col-3">
                        <a class="text-muted" href="{{ path('app_import_index', {
                            ... app.request.query.all(),
                            sortBy: 'name',
                            orderBy: sortBy == 'name' and orderBy == 'asc' ? 'desc' : 'asc',
                        }) }}">
                            {{ 'label.name'|trans({}, 'messages') }} {{ pagination.sortArrow('name', sortBy, orderBy) }}
                        </a>
                    </th>
                    <th class="col-1">
                        <a class="text-muted" href="{{ path('app_import_index', {
                            ... app.request.query.all(),
                            sortBy: 'status',
                            orderBy: sortBy == 'status' and orderBy == 'asc' ? 'desc' : 'asc',
                        }) }}">
                            {{ 'label.status'|trans({}, 'messages') }} {{ pagination.sortArrow('status', sortBy, orderBy) }}
                        </a>
                    </th>
                    <th class="col-2">
                        <a class="text-muted" href="{{ path('app_import_index', {
                            ... app.request.query.all(),
                            sortBy: 'hospital',
                            orderBy: sortBy == 'hospital' and orderBy == 'asc' ? 'desc' : 'asc',
                        }) }}">
                            {{ 'label.hospital'|trans({}, 'messages') }} {{ pagination.sortArrow('hospital', sortBy, orderBy) }}
                        </a>
                    </th>
                    <th class="col-2">
                        <a class="text-muted" href="{{ path('app_import_index', {
                            ... app.request.query.all(),
                            sortBy: 'createdAt',
                            orderBy: sortBy == 'createdAt' and orderBy == 'asc' ? 'desc' : 'asc',
                        }) }}">
                            {{ 'label.created_at'|trans({}, 'messages') }} {{ pagination.sortArrow('createdAt', sortBy, orderBy) }}
                        </a>
                    </th>
                    <th class="col-2">
                        <a class="text-muted" href="{{ path('app_import_index', {
                            ... app.request.query.all(),
                            sortBy: 'lastChange',
                            orderBy: sortBy == 'lastChange' and orderBy == 'asc' ? 'desc' : 'asc',
                        }) }}">
                            {{ 'label.last_changed_at'|trans({}, 'messages') }} {{ pagination.sortArrow('lastChange', sortBy, orderBy) }}
                        </a>
                    </th>
                    <th class="col-2">
                        {{ 'label.last_changed_by'|trans({}, 'messages') }}
                    </th>
                </tr>
                </thead>
                <tbody>
                {% for import in paginator.results %}
                    {% import '@Shared/_macros/status.html.twig' as macros %}
                    <tr>
                        <td>
                            <span class="status status-blue">{{ import.type.value }}</span>
                        </td>
                        <td>
                            <a href="{{ path('app_import_show', {id: import.id}) }}" target="_top">{{ import.name }}</a>
                        </td>
                        <td>
                            {{ macros.import_status(import.status.value) }}
                        </td>
                        <td>
                            <a href="{{ path('app_explore_hospital_show', {publicId: import.hospital.publicId}) }}" target="_top">{{ import.hospital }}</a>
                        </td>
                        <td>{{ import.createdAt|date('d.m.Y H:i') }}</td>
                        <td>
                            {{ import.updatedAt ? import.updatedAt|date('d.m.Y H:i') : import.createdAt|date('d.m.Y H:i') }}
                        </td>
                        <td>
                            {{ import.updatedBy ? import.updatedBy : import.createdBy }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7">
                            <div class="empty">
                                <div class="empty-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                        <circle cx="12" cy="12" r="9" />
                                        <line x1="9" y1="10" x2="9.01" y2="10" />
                                        <line x1="15" y1="10" x2="15.01" y2="10" />
                                        <path d="M9.5 15.25a3.5 3.5 0 0 1 5 0" />
                                    </svg>
                                </div>
                                <p class="empty-title">{{ 'label.search_no_results'|trans({}, 'messages') }}</p>
                                <p class="empty-subtitle text-secondary">
                                    {{ 'help.search_no_results'|trans({}, 'shared') }}
                                </p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </twig:DataTable>

        <turbo-stream action="replace" target="result-count">
            <template>
                {{ block('result_count') }}
            </template>
        </turbo-stream>
    </turbo-frame>

    <div
        class="offcanvas offcanvas-end"
        tabindex="-1"
        id="import-filters"
        aria-labelledby="import-filters-label"
    >
        <div class="offcanvas-header">
            <h2 class="offcanvas-title" id="import-filters-label">
                {{ 'label.filter.results'|trans({}, 'messages') }}
            </h2>
            <button
                type="button"
                class="btn-close"
                data-bs-dismiss="offcanvas"
                aria-label="Close"
            ></button>
        </div>
        <div class="offcanvas-body">
            <form method="get" action="{{ path('app_import_index') }}">
                {% for key, value in app.request.query.all %}
                    {% if key not in ['hospitalId', 'ownerId', 'status', 'createdFrom', 'createdUntil'] and value is not iterable %}
                        <input type="hidden" name="{{ key }}" value="{{ value }}">
                    {% endif %}
                {% endfor %}

                <div class="mb-3">
                    <label class="form-label" for="import-filter-hospital">{{ 'label.hospital'|trans({}, 'messages') }}</label>
                    <select name="hospitalId" id="import-filter-hospital" class="form-select">
                        <option value="">{{ 'label.import.filter.all_hospitals'|trans({}, 'import') }}</option>
                        {% for hospital in hospitals %}
                            <option
                                value="{{ hospital.id }}"
                                {{ filters.hospitalId == hospital.id ? 'selected' }}
                            >
                                {{ hospital.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="import-filter-owner">{{ 'label.import.filter.owner'|trans({}, 'import') }}</label>
                    <select name="ownerId" id="import-filter-owner" class="form-select">
                        <option value="">{{ 'label.import.filter.all_owners'|trans({}, 'import') }}</option>
                        {% for owner in owners %}
                            <option
                                value="{{ owner.id }}"
                                {{ filters.ownerId == owner.id ? 'selected' }}
                            >
                                {{ owner.username }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="import-filter-status">{{ 'label.status'|trans({}, 'messages') }}</label>
                    <select name="status" id="import-filter-status" class="form-select">
                        <option value="">{{ 'label.import.filter.all_statuses'|trans({}, 'import') }}</option>
                        {% for status in statuses %}
                            <option
                                value="{{ status.value }}"
                                {{ filters.status == status.value ? 'selected' }}
                            >
                                {{ status.value }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="import-filter-created-from">{{ 'label.import.filter.created_from'|trans({}, 'import') }}</label>
                    <input
                        type="date"
                        name="createdFrom"
                        id="import-filter-created-from"
                        class="form-control"
                        value="{{ filters.createdFrom }}"
                    >
                </div>

                <div class="mb-3">
                    <label class="form-label" for="import-filter-created-until">{{ 'label.import.filter.created_until'|trans({}, 'import') }}</label>
                    <input
                        type="date"
                        name="createdUntil"
                        id="import-filter-created-until"
                        class="form-control"
                        value="{{ filters.createdUntil }}"
                    >
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary w-100">
                        {{ 'label.filters.apply'|trans({}, 'messages') }}
                    </button>
                    {% if activeFilterCount > 0 %}
                        <a
                            href="{{ path('app_import_index', {search: search, sortBy: sortBy, orderBy: orderBy}) }}"
                            class="btn btn-link w-100"
                        >
                            {{ 'label.filters.reset'|trans({}, 'messages') }}
                        </a>
                    {% endif %}
                </div>
            </form>
        </div>
    </div>
{% endblock %}
