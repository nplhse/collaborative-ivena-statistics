<div class="card border-primary" data-testid="dashboard-participant-access-notice">
    <div class="card-header bg-primary-lt">
        <h3 class="card-title mb-0 d-inline-flex align-items-center gap-2">
            <twig:ux:icon name="tabler:info-circle" style="height: 1.25em;" />
            {{ 'dashboard.participant_access.title'|trans }}
        </h3>
    </div>
    <div class="card-body d-flex flex-column gap-3">
        <p class="text-secondary mb-0">{{ 'dashboard.participant_access.intro'|trans }}</p>

        <div>
            <p class="fw-medium mb-2">{{ 'dashboard.participant_access.includes_title'|trans }}</p>
            <ul class="mb-0 ps-3">
                <li>{{ 'dashboard.participant_access.includes.explore'|trans }}</li>
                <li>{{ 'dashboard.participant_access.includes.import'|trans }}</li>
                <li>{{ 'dashboard.participant_access.includes.hospitals'|trans }}</li>
                <li>{{ 'dashboard.participant_access.includes.stats_scope'|trans }}</li>
                <li>{{ 'dashboard.participant_access.includes.analytics'|trans }}</li>
            </ul>
        </div>

        <div>
            <p class="fw-medium mb-2">{{ 'dashboard.participant_access.contact_title'|trans }}</p>
            <button type="button"
                    class="btn btn-primary d-inline-flex align-items-center gap-1"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#feedbackOffcanvas"
                    aria-controls="feedbackOffcanvas"
                    data-testid="dashboard-participant-access-feedback">
                <twig:ux:icon name="tabler:message-circle" style="height: 1.2em;" />
                {{ 'dashboard.participant_access.contact_feedback'|trans }}
            </button>
        </div>
    </div>
</div>
