<div class="card border-primary" data-testid="dashboard-onboarding-card" data-controller="onboarding-card">
    <div class="card-header bg-primary-lt">
        <h3 class="card-title mb-0 d-inline-flex align-items-center gap-2">
            <twig:ux:icon name="tabler:list-check" style="height: 1.25em;" />
            {{ 'onboarding.card.title'|trans({}, 'onboarding') }}
        </h3>
    </div>
    <div class="card-body d-flex flex-column gap-3">
        <p class="text-secondary mb-0">{{ 'onboarding.card.intro'|trans({}, 'onboarding') }}</p>

        {% if onboardingCard.completedCount > 0 %}
            <div data-testid="dashboard-onboarding-progress">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                    <span class="small text-secondary">
                        {{ 'onboarding.card.progress'|trans(({
                            completed: onboardingCard.completedCount,
                            total: onboardingCard.totalCount,
                        }), 'onboarding') }}
                    </span>
                    {% if onboardingCard.completedSteps is not empty %}
                        <button type="button"
                                class="btn btn-ghost-secondary btn-sm p-1"
                                data-onboarding-card-target="popoverTrigger"
                                data-bs-toggle="popover"
                                data-bs-placement="left"
                                data-bs-trigger="hover focus"
                                data-bs-html="true"
                                data-bs-title="{{ 'onboarding.card.completed_popover_title'|trans({}, 'onboarding')|e('html_attr') }}"
                                data-bs-content="{{ include('@Content/dashboard/_onboarding_completed_steps_popover.html.twig', {
                                    completedSteps: onboardingCard.completedSteps,
                                })|e('html_attr') }}"
                                aria-label="{{ 'onboarding.card.completed_popover_title'|trans({}, 'onboarding') }}"
                                data-testid="dashboard-onboarding-completed-popover">
                            <twig:ux:icon name="tabler:info-circle" style="height: 1.1em;" />
                        </button>
                    {% endif %}
                </div>
                <div class="progress progress-sm">
                    <div class="progress-bar bg-primary"
                         style="width: {{ onboardingCard.progressPercent }}%"
                         role="progressbar"
                         aria-valuenow="{{ onboardingCard.progressPercent }}"
                         aria-valuemin="0"
                         aria-valuemax="100"
                         aria-label="{{ 'onboarding.card.progress'|trans(({
                             completed: onboardingCard.completedCount,
                             total: onboardingCard.totalCount,
                         }), 'onboarding') }}"></div>
                </div>
            </div>
        {% endif %}

        <div class="border rounded overflow-hidden">
            <ul class="list-unstyled mb-0">
                {% for step in onboardingCard.openSteps %}
                    <li class="p-3{% if not loop.last %} border-bottom{% endif %}{% if not step.isActionable %} bg-light{% endif %}"
                        data-testid="onboarding-step-{{ step.key.value }}"
                        {% if not step.isActionable %}data-testid-onboarding-locked="true"{% endif %}>
                        <div class="fw-medium mb-1 d-flex align-items-center gap-2{% if not step.isActionable %} text-secondary{% endif %}">
                            <span class="badge {% if step.isActionable %}bg-primary-lt text-primary{% else %}bg-secondary-lt text-secondary{% endif %} rounded-pill flex-shrink-0"
                                  aria-hidden="true">{{ step.position }}</span>
                            <span>{{ step.title|trans }}</span>
                        </div>
                        {% if step.isActionable %}
                            <p class="text-secondary small mb-2">{{ step.description|trans }}</p>
                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div class="d-flex align-items-center">
                                    {% if step.actionType == 'feedback' %}
                                        <button type="button"
                                                class="btn btn-primary btn-sm d-inline-flex align-items-center gap-1"
                                                data-controller="onboarding-step"
                                                data-onboarding-step-message-value="{{ step.feedbackMessage is not null ? step.feedbackMessage|trans|e('html_attr') : '' }}"
                                                data-action="onboarding-step#openClinicAccessFeedback">
                                            {{ 'onboarding.steps.request_clinic_access.action'|trans({}, 'onboarding') }}
                                            <twig:ux:icon name="tabler:message-circle" class="onboarding-step-action-icon" style="height: 1.1em;" />
                                        </button>
                                    {% elseif step.actionUrl %}
                                        {% set stepActionIcon = {
                                            verify_own_clinic: 'tabler:building-hospital',
                                            start_first_import: 'tabler:database-import',
                                            view_explore_data: 'tabler:compass',
                                            view_overview_statistics: 'tabler:graph',
                                        }[step.key.value] ?? 'tabler:arrow-right' %}
                                        <a href="{{ step.actionUrl }}" class="btn btn-outline-primary btn-sm d-inline-flex align-items-center gap-1">
                                            {{ ('onboarding.steps.' ~ step.key.value ~ '.action')|trans({}, 'onboarding') }}
                                            <twig:ux:icon name="{{ stepActionIcon }}" class="onboarding-step-action-icon" style="height: 1.1em;" />
                                        </a>
                                    {% endif %}
                                </div>
                                <form method="post"
                                      action="{{ path('app_onboarding_step_complete', {stepKey: step.key.value}) }}"
                                      class="mb-0 flex-shrink-0">
                                    <input type="hidden" name="_token" value="{{ csrf_token('onboarding_complete_' ~ step.key.value) }}">
                                    <button type="submit" class="btn btn-outline-success btn-sm d-inline-flex align-items-center gap-1">
                                        {{ 'onboarding.action.mark_complete'|trans({}, 'onboarding') }}
                                        <twig:ux:icon name="tabler:check" class="onboarding-step-action-icon" style="height: 1.1em;" />
                                    </button>
                                </form>
                            </div>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</div>
