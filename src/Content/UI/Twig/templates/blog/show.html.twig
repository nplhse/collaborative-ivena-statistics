{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ post.title }} - {{ app_blog_title }} - {{ parent() }}{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs
            :items="[
                { label: 'link.blog', path: path('app_blog_index') },
                { label: post.title }
            ]"
        />
        <div class="row align-items-center mt-1">
            <div class="col">
                <h1 class="fw-bold mb-1">{{ post.title }}</h1>
                <div class="list-inline list-inline-dots text-muted">
                    <div class="list-inline-item">
                        <twig:ux:icon name="tabler:calendar-event" class="w-3 h-3" />
                        {{ post.publishedAt|date('d.m.Y H:i') }}
                    </div>
                    <div class="list-inline-item">
                        <twig:ux:icon name="tabler:user" class="w-3 h-3" />
                        {{ 'blog.meta.author'|trans }}
                        {{ post.createdBy ?: 'blog.meta.unknown_author'|trans }}
                    </div>
                </div>
                <div class="list-inline list-inline-dots text-muted mt-1">
                    <div class="list-inline-item">
                        <twig:ux:icon name="tabler:folder" class="w-3 h-3" />
                        {{ 'blog.meta.category'|trans }}
                        <a class="badge bg-blue-lt text-blue-emphasis ms-1" href="{{ path('app_blog_category', {slug: post.category.slug}) }}">{{ post.category.name }}</a>
                    </div>
                {% if post.tags|length > 0 %}
                    <div class="list-inline-item">
                        <twig:ux:icon name="tabler:tags" class="w-3 h-3 text-muted" />
                        {{ 'blog.meta.tags'|trans }}
                        {% for tag in post.tags %}
                            <a class="badge bg-azure-lt" href="{{ path('app_blog_tag', {slug: tag.slug}) }}">{{ tag.name }}</a>
                        {% endfor %}
                    </div>
                {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_body %}
    <div class="page-body">
        <div class="container-xl">
            <div class="row g-3">
                <div class="col-lg-8">
                    <article class="card mb-4">
                        <div class="card-body">
                            <div class="content page-content-blocks"
                                 data-controller="lightbox"
                                 data-lightbox-gallery-value="content-gallery">
                                {{ content|raw }}
                            </div>
                        </div>
                    </article>

                    <section class="card">
                        <div class="card-header d-flex align-items-center justify-content-between bg-light">
                            <h2 class="card-title mb-0">{{ 'blog.comments.title'|trans }}</h2>
                            <span class="badge bg-secondary-lt">{{ 'blog.comments.count'|trans({count: comments|length}) }}</span>
                        </div>
                        <div class="card-body">
                            {% if is_granted('ROLE_USER') %}
                                <form method="post" action="{{ path('app_blog_comment_create', {slug: post.slug}) }}" class="mb-4">
                                    <input type="hidden" name="_token" value="{{ csrf_token('comment_' ~ post.id) }}">
                                    <textarea name="content" class="form-control mb-2" rows="4" required placeholder="{{ 'blog.comments.placeholder'|trans }}"></textarea>
                                    <button type="submit" class="btn btn-primary">{{ 'blog.comments.submit'|trans }}</button>
                                </form>
                            {% else %}
                                <div class="alert alert-info">
                                    {{ 'blog.comments.login_required'|trans }}
                                    <a class="btn btn-sm" href="{{ path('app_login') }}">{{ 'label.login'|trans }}</a>
                                </div>
                            {% endif %}

                            <div class="d-flex flex-column gap-3">
                                {% for comment in comments %}
                                    {{ include('@Content/blog/_comment.html.twig', {post: post, comment: comment, level: 0}) }}
                                {% else %}
                                    {% if is_granted('ROLE_USER') %}
                                    <div class="alert alert-info mb-0">
                                        <div class="fw-semibold">{{ 'blog.comments.empty'|trans }}</div>
                                        <div class="text-secondary">{{ 'blog.comments.first_cta'|trans }}</div>
                                    </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    </section>

                    {% if previous_post is defined or next_post is defined %}
                        <div class="card mt-3">
                            <div class="card-body">
                                <ul class="pagination">
                                    <li class="page-item page-prev {{ previous_post is defined and previous_post ? '' : 'disabled' }}">
                                        {% if previous_post is defined and previous_post %}
                                            <a class="page-link" href="{{ path('app_blog_show', {slug: previous_post.slug}) }}">
                                                <div class="page-item-subtitle">{{ 'blog.pagination.previous_lower'|trans }}</div>
                                                <div class="page-item-title">{{ previous_post.title }}</div>
                                            </a>
                                        {% else %}
                                            <a class="page-link" href="#" tabindex="-1" aria-disabled="true">
                                                <div class="page-item-subtitle">{{ 'blog.pagination.previous_lower'|trans }}</div>
                                                <div class="page-item-title">{{ 'blog.pagination.none'|trans }}</div>
                                            </a>
                                        {% endif %}
                                    </li>
                                    <li class="page-item page-next {{ next_post is defined and next_post ? '' : 'disabled' }}">
                                        {% if next_post is defined and next_post %}
                                            <a class="page-link" href="{{ path('app_blog_show', {slug: next_post.slug}) }}">
                                                <div class="page-item-subtitle">{{ 'blog.pagination.next_lower'|trans }}</div>
                                                <div class="page-item-title">{{ next_post.title }}</div>
                                            </a>
                                        {% else %}
                                            <a class="page-link" href="#" tabindex="-1" aria-disabled="true">
                                                <div class="page-item-subtitle">{{ 'blog.pagination.next_lower'|trans }}</div>
                                                <div class="page-item-title">{{ 'blog.pagination.none'|trans }}</div>
                                            </a>
                                        {% endif %}
                                    </li>
                                </ul>
                            </div>
                        </div>
                    {% endif %}
                </div>
                <div class="col-lg-4">
                    {{ include('@Content/blog/_sidebar.html.twig', {show_about: false}) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
