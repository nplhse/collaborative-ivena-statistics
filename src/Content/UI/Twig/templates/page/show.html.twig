{% extends '@Shared/_layout_vertical.html.twig' %}

{% block title %}{{ page.title }} - {{ parent() }}{% endblock %}

{% block page_header %}
    <div class="container-xl">
        <twig:Breadcrumbs :items="breadcrumbItems" />
        <h1 class="fw-bold mb-1">{{ page.title }}</h1>
    </div>
{% endblock %}

{% block page_body %}
    <div class="page-body">
        <div class="container-xl">
            <div class="row g-3">
                <div class="col-lg-8">
                    {% for block in page.content %}
                        {% if block.enabled is not defined or block.enabled %}
                            {% if block.type in ['richtext', 'image', 'cta', 'quote'] %}
                                {{ include('@Content/page/blocks/' ~ block.type ~ '.html.twig', {block: block}) }}
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </div>
                <div class="col-lg-4">
                    {{ include('@Content/page/_sidebar.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
