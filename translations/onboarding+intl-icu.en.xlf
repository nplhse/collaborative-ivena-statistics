      <trans-unit id="OnbCardEn03" resname="onboarding.card.progress">
        <source>onboarding.card.progress</source>
        <target>{completed} of {total} completed</target>
      </trans-unit>
      <trans-unit id="OnbCardEn04" resname="onboarding.card.completed_popover_title">
        <source>onboarding.card.completed_popover_title</source>
