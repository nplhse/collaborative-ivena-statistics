#!/usr/bin/env php
<?php

declare(strict_types=1);

$cacheFile = dirname(__DIR__).'/.phpunit.cache/test-results';

if (!is_file($cacheFile)) {
    fwrite(STDERR, "No PHPUnit duration cache at {$cacheFile}. Run the test suite first.\n");
    exit(1);
}

$data = json_decode(file_get_contents($cacheFile), true, flags: JSON_THROW_ON_ERROR);
$times = $data['times'] ?? [];

if ($times === []) {
    fwrite(STDERR, "Duration cache is empty.\n");
    exit(1);
}

arsort($times);

$limit = (int) ($argv[1] ?? 10);
$limit = max(1, $limit);

echo "Slowest {$limit} tests (from PHPUnit duration cache):\n";

$i = 0;
foreach ($times as $test => $duration) {
    printf("%6.2fs  %s\n", $duration, $test);
    if (++$i >= $limit) {
        break;
    }
}
