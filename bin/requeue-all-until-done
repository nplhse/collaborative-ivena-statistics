#!/usr/bin/env bash
set -euo pipefail

MAX_RETRIES_PER_IMPORT="${MAX_RETRIES_PER_IMPORT:-3}"
SLEEP_SECONDS="${SLEEP_SECONDS:-10}"
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$PROJECT_DIR"

while true; do
    php bin/console app:import:requeue-all \
        --resume \
        --max-retries-per-import="$MAX_RETRIES_PER_IMPORT"
    EXIT_CODE=$?

    if [[ "$EXIT_CODE" -eq 0 ]]; then
        echo "All imports dispatched successfully."
        exit 0
    fi

    if [[ "$EXIT_CODE" -eq 2 ]]; then
        echo "Critical failure (exit $EXIT_CODE); not restarting." >&2
        exit 2
    fi

    echo "Retryable failure (exit $EXIT_CODE); restarting after ${SLEEP_SECONDS}s…"
    sleep "$SLEEP_SECONDS"
done
